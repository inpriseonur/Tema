    <!-- =====================================================
        MOBİL ÜRÜN SAYFASI OPTİMİZASYONU
        Amaç: Mobilde varyant/adet seçeneklerinin scroll 
        olmadan görünmesi ve sticky satın alma butonu
        ===================================================== -->
    <style>
      @media screen and (max-width: 749px) {

        /* Ürün görseli altındaki thumbnail slider'ı mobilde gizle */
        .pro-slider,
        .slider-small {
          display: none !important;
        }

        /* Orijinal fiyat alanını gizle — sticky bar'da gösterileceği için.
          Adet ve varyant seçeneklerinin scroll olmadan görünmesi sağlanır. */
        .pro-price-label {
          visibility: hidden;
          height: 0 !important;
          overflow: hidden;
          margin: 0 !important;
          padding: 0 !important;
        }

        /* Sticky satın alma butonu — ekranın altına sabitlenir */
        cart-action.product-form .pr-form-button {
          position: fixed;
          bottom: 0;
          left: 0;
          right: 0;
          z-index: 999;
          padding: 10px 16px !important;
          margin: 0 !important;
          background: #fff;
          box-shadow: 0 -2px 8px rgba(0,0,0,0.15);
          display: flex;
          flex-direction: column;
          align-items: stretch;
          justify-content: center;
          gap: 10px;
        }

        .sticky-top-row {
          display: flex;
          align-items: center;
          justify-content: center;
          width: 100%;
          gap: 5px;
        }


        /* Sticky bar içindeki CTA butonu tam genişlik */
        cart-action.product-form .ajax-cart-btn {
          flex: 1;
          margin: 0 !important;
          display: flex !important;
          width: 100% !important;
          max-width: 100% !important;
          padding-top: 14px !important;
          padding-bottom: 14px !important;
          font-size: 15px !important;
          border-radius: 6px;
        }

        /* Sepet yan paneli açıkken sticky butonu gizle —
          panel altındaki ödeme butonları görünür kalsın */
        ajax-cart.open ~ * cart-action.product-form .pr-form-button,
        ajax-cart.active ~ * cart-action.product-form .pr-form-button,
        ajax-cart[open] ~ * cart-action.product-form .pr-form-button {
          display: none !important;
        }

        /* Mobilde görsel container boşluklarını sıfırla */
        .product_detail_img {
          margin-bottom: 0 !important;
          padding-bottom: 0 !important;
        }

        .product_details.detail-info {
          margin-top: -30px !important;
          padding-top: 0 !important;
        }

        /* Genel ürün detay container boşluklarını sıkıştır */
        .product-details .container {
          padding-top: 4px !important;
        }

        .detail-wrap {
          gap: 4px !important;
        }

        /* Mobilde görsel ile metin arasındaki 30px boşluğu sıfırla, sol-sağ padding'i geri getir */
        .product-details .detail-wrap .product_details {
          margin: 0 !important;
        }
        .product-content, .product_details_info {
          padding-left: 16px !important;
          padding-right: 16px !important;
        }

        /* Mobilde üst duyuru/bildirim barını gizle */
        #shopify-section-sections--20682889035821__top-nocification-bar {
          display: none !important;
        }

        /* =====================================================
           QUICK VIEW (HIZLI GÖZAT) İSTİSNALARI
           Hızlı gözat penceresinde fiyat ve butonları modal içinde gösterir.
           ===================================================== */
        .quickview-modal .pro-price-label {
          visibility: visible !important;
          height: auto !important;
          overflow: visible !important;
          margin: 15px 0 !important;
          padding: 0 !important;
        }

        .quickview-modal cart-action.product-form .pr-form-button {
          position: relative !important;
          bottom: auto !important;
          left: auto !important;
          right: auto !important;
          z-index: 1 !important;
          padding: 10px 0 !important;
          margin: 15px 0 0 !important;
          background: transparent !important;
          box-shadow: none !important;
          display: flex !important;
          opacity: 1 !important;
          flex-wrap: wrap;
        }

        .quickview-modal cart-action.product-form .pr-form-button .ajax-cart-btn,
        .quickview-modal cart-action.product-form .pr-form-button .shopify-payment-button {
          width: 100% !important;
          flex: none !important;
          margin: 10px 0 0 !important;
        }

        .quickview-modal .product_details.detail-info {
          margin-top: 0 !important;
        }

        /* =====================================================
           UX / UI OPTİMİZASYONLARI (BAŞLIK, VARYANT, HEADER)
           ===================================================== */
        /* Header, Logo ve İkonları Küçültme */
        .header-main {
          padding-top: 12px !important;
          padding-bottom: 12px !important;
        }
        .header-main .logo img {
          max-width: 105px !important;
          height: auto !important;
        }
        /* İkonların (kalp, sepet vb.) kesilmemesi ve biraz küçülmesi için */
        .header-main svg {
          max-height: 22px !important;
          width: auto !important;
        }

        /* Başlık küçültme */
        .product_details_info .product-title h1,
        .product_details_info .product-title h2 {
          font-size: 15px !important;
          font-weight: 700 !important;
          line-height: 1.3 !important;
        }

        /* Başlık ile varyant arasındaki boşluğu daraltma */
        .product_details_info .product-title {
          margin-bottom: 12px !important;
          padding-bottom: 12px !important;
        }
        
        /* Varyant Etiketi (Şişe Boyutu: ...) */
        .product_details_info .pr-option .option-title,
        .product_details_info .pr-option .option-title .current-option {
          font-size: 13px !important;
          color: #6b7280 !important;
        }

        /* Varyant Butonları (Tüm Kutular) - Specificity Artırıldı */
        body .product_details_info .pr-option .option-block label.op-lb {
          height: 40px !important;
          padding: 0 10px !important;
          font-size: 12px !important;
          border-radius: 8px !important;
          display: inline-flex !important;
          align-items: center !important;
          justify-content: center !important;
          margin-bottom: 5px !important;
        }
        .product_details_info .pr-option {
          margin-bottom: 12px !important;
        }

        /* Adet (Quantity) Alanı Küçültme ve Boşluk */
        .product_details_info .product-qty {
          margin-top: 10px !important;
          margin-bottom: 12px !important;
        }
        .product_details_info .product-qty h6.qty-head {
          font-size: 14px !important;
          margin-bottom: 5px !important;
        }
        .product_details_info .product-qty .qty-box {
          height: 36px !important;
          width: 110px !important;
        }
        .product_details_info .product-qty .qty-box .qty-bt {
          width: 36px !important;
          height: 36px !important;
        }
        .product_details_info .product-qty .qty-box .qty-box-input {
          height: 36px !important;
          font-size: 14px !important;
        }

        /* Varyantın hemen altındaki güven ikonları satırı */
        .product_details_info .desktop-cta-trust {
          margin-top: 5px !important;
          margin-bottom: 12px !important;
          justify-content: flex-start !important; /* Sola hizala */
        }
        .product_details_info .desktop-cta-trust .trust-item {
          font-size: 11px !important;
        }
        .product_details_info .desktop-cta-trust svg {
          width: 14px !important;
          height: 14px !important;
        }

        /* Kapıda Ödeme Bandı (cod_message block) Küçültme */
        .product_details_info .product-cod-message {
          padding: 10px 12px !important;
          margin-bottom: 8px !important;
          height: 46px !important;
        }
        .product_details_info .product-cod-message .cod-icon {
          width: 22px !important;
          height: 22px !important;
        }
        .product_details_info .product-cod-message .cod-icon svg {
          width: 12px !important;
          height: 12px !important;
        }
        .product_details_info .product-cod-message .cod-title {
          font-size: 12px !important;
          margin-bottom: 0 !important;
        }
        .product_details_info .product-cod-message .cod-subtitle {
          font-size: 11px !important;
        }
        .product_details_info .product-cod-message .cod-badge {
          font-size: 11px !important;
          padding: 2px 6px !important;
        }


      }

      /* =====================================================
         ÜRÜN SAYFASI — MOBİL FOOTER SADELEŞTİRME
         Footer menü bloğunu (ANA MENÜ, KURUMSAL, newsletter)
         ve alt sticky nav'ı gizle, sadece copyright barı kalsın.
         Copyright barının sticky satın alma barının altında
         kalmaması için body'ye alt padding ekle.
         ===================================================== */
      @media screen and (max-width: 749px) {
        /* Footer üst bloğu gizle (ANA MENÜ, KURUMSAL, newsletter) */
        body.template-product .footer-top-area {
          display: none !important;
        }

        /* Mobil alt sticky menü (Home/Search/Wishlist/Account) gizle */
        body.template-product .mobile-sticky-menu {
          display: none !important;
        }

        /* Copyright barı sticky satın alma barının arkasında kalmasın */
        body.template-product {
          padding-bottom: 130px;
        }
      }
    </style>


  </head>
  <body  id="{{ page_title | handle }}" class="template-{{ template.name | handle }}">
    {%- if template == 'index' and settings.newsletter_popup_enable -%}
    {% include 'newsletter-popup' %}
    {%- endif -%}
    {%- if settings.cart_type == 'drawer' -%}
    {%- render 'ajax-cart' -%}
    {%- endif -%}
    {% sections 'header-group' %}
    {%- if template != 'index' -%}
    {% include 'breadcrumb-banner' %}
    {%- endif -%}
    <main role="main">
      {{ content_for_layout }}
    </main>
    <div class="mm-fullscreen-bg"></div>
    {% sections 'footer-group' %}
    <script type="text/javascript">
      
      window.money_format = '{{ shop.money_format }}';
      window.pro_id = '{{ product.id }}';
      window.routes = {
        increase_cart_url: '{{ routes.cart_add_url }}',
        edite_cart_url: '{{ routes.cart_change_url }}',
        change_cart_url: '{{ routes.cart_update_url }}',
        cart_url: '{{ routes.cart_url }}',
        ajax_search_url: '{{ routes.predictive_search_url }}'
      };
      window.stCartString = {
        error: `{{ 'sections.cart.cart_error' | t }}`,
        qtyError: `{{ 'sections.cart.cart_quantity_error_html' | t: quantity: '[quantity]' }}`
      }
      window.stThemeString = {
        Straddcart: `{{ 'products.product.add_to_cart' | t }}`,
        Strsoldout: `{{ 'products.product.sold_out' | t }}`,
        Strunavailable: `{{ 'products.product.unavailable' | t }}`,
        StrunavailableOp: `{{ 'products.product.value_unavailable' | t: option_value: '[value]' }}`,
      }
      
    </script>
    {%- if settings.ajax_search_enabled -%}
    <script src="{{ 'search-ajax.js' | asset_url }}" defer="defer"></script>
    {%- endif -%}
    <!-- Sticky bar'a dinamik fiyat bilgisini yazar — orijinal class'lar ve stiller korunur -->
    <script>
      
      /* Thumbnail slider'ı gizle, FOUC önle ve desktop'ta sticky fiyatı gizle */
      var style = document.createElement('style');
      style.textContent = `
        @media screen and (max-width: 749px) { 
          .pro-slider, .slider-small { display: none !important; } 
          .slider-big .big-button { display: none !important; }
          .mobile-sticky-price {
            display: flex;
            justify-content: center;
            width: 100%;
          }
          .mobile-sticky-price .price-box { 
            display: flex;
            align-items: center;
            justify-content: center;
            flex-wrap: nowrap;
            gap: 8px;
          }
          .mobile-sticky-price .new-price {
            font-size: 20px !important;
            font-weight: 800 !important;
            line-height: 1;
            margin: 0 !important;
            color: #1a2b4c;
          }
          .mobile-sticky-price .old-price {
            font-size: 13px !important;
            margin: 0 !important;
            line-height: 1;
          }
          .mobile-sticky-price .unit-price {
            padding-inline-start: 0 !important;
            font-size: 11px !important;
            line-height: 1;
            color: #5f6b82;
          }
          .mobile-sticky-price .unit-price-desktop {
            display: none !important;
          }
          .mobile-sticky-price .unit-price-mobile {
            display: inline !important;
          }
          .mobile-sticky-price .price-box.has-compare-price .unit-price,
          .mobile-sticky-price .price-box:has(.old-price:not(.d-none)) .unit-price {
            display: none !important;
          }
          .mobile-sticky-price.is-volume-price .unit-price {
            display: none !important;
          }
          .mobile-sticky-price .product-label {
            margin: 0 !important;
            transform: scale(0.9);
            transform-origin: center;
          }
          .bundle-product .mobile-sticky-price .product-label {
            display: none !important;
          }
        }
        @media screen and (min-width: 750px) { .sticky-top-row, .mobile-sticky-price { display: none !important; } }
        .slider-big:not(.swiper-initialized) .swiper-slide:not(:first-child) { display: none !important; }
      `;
      document.head.insertBefore(style, document.head.firstChild);
      document.addEventListener('DOMContentLoaded', function() {
        var priceBox = document.getElementById('price-template--20682888151085__product-template') || document.querySelector('.pro-price-label .price-box');
        var discountLabel = document.querySelector('.product-label');
        var btn = document.querySelector('cart-action.product-form .pr-form-button');
        if (priceBox && btn) {
          var wrapper = document.createElement('div');
          wrapper.className = 'mobile-sticky-price';

          var priceClone = priceBox.cloneNode(true);
          priceClone.classList.toggle('has-compare-price', !!priceClone.querySelector('.old-price:not(.d-none)'));
          wrapper.appendChild(priceClone);

          if (discountLabel && !priceClone.querySelector('.product-label')) {
            var discountClone = discountLabel.cloneNode(true);
            /* % işareti CSS pseudo-element ile gelmediyse manuel ekle */
            var percentEl = discountClone.querySelector('.percent-count');
            if (percentEl && !percentEl.textContent.includes('%')) {
              percentEl.textContent = '%' + percentEl.textContent.trim();
            }
            // İndirim balonunu fiyat kutusunun içine ekle
            priceClone.appendChild(discountClone);
          }

          // Üst satırı (fiyat + ikonlar) oluştur
          var topRow = document.createElement('div');
          topRow.className = 'sticky-top-row';
          topRow.appendChild(wrapper); // Fiyat kutusunu ekle



          // Hazırlanan üst satırı butondan önceye ekle
          btn.prepend(topRow);

          // Stok bilgisini adet kutusunun yanına taşı
          var qtyContainer = document.querySelector('.product-qty');
          var inventory = document.querySelector('.product-inventory');
          if (qtyContainer && inventory) {
            qtyContainer.appendChild(inventory);
            inventory.style.marginTop = '0';
            inventory.style.marginLeft = '15px';
          }

          // Varyant değiştiğinde klonları güncellemek için Observer
          var observer = new MutationObserver(function() {
            priceClone.innerHTML = priceBox.innerHTML;
            priceClone.classList.toggle('has-compare-price', !!priceClone.querySelector('.old-price:not(.d-none)'));
            var clonedLabel = priceClone.querySelector('.product-label');
            if (clonedLabel) {
              var clonedPercent = clonedLabel.querySelector('.percent-count');
              if (clonedPercent && !clonedPercent.textContent.includes('%')) {
                clonedPercent.textContent = '%' + clonedPercent.textContent.trim();
              }
            } else if (discountLabel && discountClone) {
              discountClone.innerHTML = discountLabel.innerHTML;
              var pEl = discountClone.querySelector('.percent-count');
              if (pEl && !pEl.textContent.includes('%')) {
                pEl.textContent = '%' + pEl.textContent.trim();
              }
              discountClone.style.display = discountLabel.style.display;
              // İndirim balonunu her seferinde tekrar fiyat kutusuna iliştir
              priceClone.appendChild(discountClone);
            }
          });
          observer.observe(priceBox, { childList: true, subtree: true, characterData: true, attributes: true });
          if (discountLabel) {
            observer.observe(discountLabel, { childList: true, subtree: true, characterData: true, attributes: true });
          }
        }

        /* CTA butonu hazır olunca göster */
        if (btn) {
          btn.style.opacity = '1';
        }
      });
    </script>

    <!-- =====================================================
         MOBİL FOOTER BOTTOM SHEET MODAL (SADECE SEPET SAYFASINDA)
         ===================================================== -->
    {% if template == 'cart' %}
    <style>
      @media screen and (max-width: 991px) {
        .footer-modal-overlay {
          position: fixed;
          top: 0;
          left: 0;
          width: 100%;
          height: 100%;
          background: rgba(0, 0, 0, 0.6);
          z-index: 99998;
          opacity: 0;
          pointer-events: none;
          transition: opacity 0.3s ease;
        }
        .footer-modal-overlay.active {
          opacity: 1;
          pointer-events: auto;
        }
        .footer-modal {
          position: fixed;
          bottom: 0;
          left: 0;
          width: 100%;
          height: 90vh;
          background: var(--color-body-bg, #fff);
          z-index: 99999;
          transform: translateY(100%);
          transition: transform 0.3s ease-out;
          border-radius: 20px 20px 0 0;
          display: flex;
          flex-direction: column;
          box-shadow: 0 -4px 15px rgba(0,0,0,0.1);
        }
        .footer-modal.active {
          transform: translateY(0);
        }
        .footer-modal-header {
          display: flex;
          justify-content: space-between;
          align-items: center;
          padding: 15px 20px;
          border-bottom: 1px solid #eee;
          background: #f9f9f9;
          border-radius: 20px 20px 0 0;
        }
        .footer-modal-title {
          font-size: 16px;
          font-weight: 700;
          color: var(--color-secondary, #333);
          margin: 0;
          text-transform: uppercase;
        }
        .footer-modal-close {
          background: none;
          border: none;
          font-size: 28px;
          line-height: 1;
          color: #999;
          cursor: pointer;
          padding: 0;
        }
        .footer-modal-close:hover {
          color: #333;
        }
        .footer-modal-body {
          flex: 1;
          overflow-y: auto;
          padding: 20px;
        }
        .footer-modal-body .loader {
          text-align: center;
          padding: 40px 0;
          color: #666;
          font-size: 14px;
        }
      }
    </style>

    <div id="footer-modal-overlay" class="footer-modal-overlay"></div>
    <div id="footer-modal" class="footer-modal">
      <div class="footer-modal-header">
        <span class="footer-modal-title" id="footer-modal-title">...</span>
        <button class="footer-modal-close" id="footer-modal-close">&times;</button>
      </div>
      <div class="footer-modal-body" id="footer-modal-body"></div>
    </div>

    <script>
      document.addEventListener('DOMContentLoaded', function() {
        if (window.innerWidth > 991) return; // Sadece mobilde
        
        var overlay = document.getElementById('footer-modal-overlay');
        var modal = document.getElementById('footer-modal');
        var closeBtn = document.getElementById('footer-modal-close');
        var modalBody = document.getElementById('footer-modal-body');
        var modalTitle = document.getElementById('footer-modal-title');

        if (!overlay || !modal) return;

        function closeModal() {
          overlay.classList.remove('active');
          modal.classList.remove('active');
          setTimeout(function() {
            modalBody.innerHTML = '';
          }, 300);
        }

        closeBtn.addEventListener('click', closeModal);
        overlay.addEventListener('click', closeModal);

        // Sepet sayfasındaki alt footer linklerini document üzerinden (event delegation ile) yakala
        document.addEventListener('click', function(e) {
          var link = e.target.closest('.cart-footer-link, .footer-bottom-area a, .footer-top-area a.ft-sublink');
          if (!link) return;

          var href = link.getAttribute('href');
          if (!href) return;
          
          var lowerHref = href.toLowerCase();
          // Sadece politika, içerik sayfaları ve hizmet şartları (policies, pages, terms, sart vb.)
          if (lowerHref.includes('/policies/') || lowerHref.includes('/pages/') || lowerHref.includes('/legal/') || lowerHref.includes('terms') || lowerHref.includes('sart')) {
            e.preventDefault();
            
            var titleText = link.textContent || link.innerText;
            modalTitle.textContent = titleText.trim();
            modalBody.innerHTML = '<div class="loader"><span class="spinner-border spinner-border-sm"></span> Yükleniyor...</div>';
            
            overlay.classList.add('active');
            modal.classList.add('active');
            
            fetch(href)
                .then(function(response) { return response.text(); })
                .then(function(html) {
                  var parser = new DOMParser();
                  var doc = parser.parseFromString(html, 'text/html');
                  
                  // İçeriği çek
                  var mainContent = doc.querySelector('main[role="main"]');
                  if (!mainContent) mainContent = doc.querySelector('.main-content');
                  
                  if (mainContent) {
                    modalBody.innerHTML = mainContent.innerHTML;
                    
                    // Gereksiz bileşenleri gizle (örn. breadcrumb vs)
                    var breadcrumbs = modalBody.querySelectorAll('.breadcrumb-area, .breadcrumb');
                    breadcrumbs.forEach(function(b){ b.style.display = 'none'; });
                  } else {
                    modalBody.innerHTML = '<div style="padding: 20px; text-align: center;">İçerik yüklenemedi.</div>';
                  }
                })
                .catch(function(err) {
                  console.error('Fetch error:', err);
                  modalBody.innerHTML = '<div style="padding: 20px; text-align: center;">Bağlantı hatası oluştu.</div>';
                });
            }
        });
      });
    </script>
    {% endif %}

  </body>
</html>
