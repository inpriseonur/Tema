{% doc %}
  @prompt
    Whatsup iconu ile birlikte telefon numarası yazmak istiyorum. Kuullanıcı buna bastığında direk yeni bir sayfada whastupweb üzerinden iletişimi başlatabilsin.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-whatsapp-contact-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-whatsapp-link-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: {{ block.settings.icon_text_gap }}px;
    padding: {{ block.settings.button_padding }}px {{ block.settings.button_padding | times: 1.5 }}px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.border_radius }}px;
    font-size: {{ block.settings.font_size }}px;
    transition: all 0.3s ease;
    border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
  }

  .ai-whatsapp-link-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    color: {{ block.settings.text_hover_color }};
    border-color: {{ block.settings.border_hover_color }};
    transform: translateY(-2px);
  }

  .ai-whatsapp-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    flex-shrink: 0;
  }

  .ai-whatsapp-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    fill: currentColor;
  }

  .ai-whatsapp-text-{{ ai_gen_id }} {
    font-weight: {{ block.settings.font_weight }};
  }

  @media screen and (max-width: 749px) {
    .ai-whatsapp-contact-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<div class="ai-whatsapp-contact-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.phone_number != blank %}
    {% assign clean_phone = block.settings.phone_number | replace: ' ', '' | replace: '-', '' | replace: '(', '' | replace: ')', '' | replace: '+', '' %}
    <a 
      href="https://wa.me/{{ clean_phone }}{% if block.settings.message != blank %}?text={{ block.settings.message | url_encode }}{% endif %}" 
      class="ai-whatsapp-link-{{ ai_gen_id }}"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="WhatsApp ile iletişime geç"
    >
      <span class="ai-whatsapp-icon-{{ ai_gen_id }}">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 448 512">
          <path d="M380.9 97.1C339 55.1 283.2 32 223.9 32c-122.4 0-222 99.6-222 222 0 39.1 10.2 77.3 29.6 111L0 480l117.7-30.9c32.4 17.7 68.9 27 106.1 27h.1c122.3 0 224.1-99.6 224.1-222 0-59.3-25.2-115-67.1-157zm-157 341.6c-33.2 0-65.7-8.9-94-25.7l-6.7-4-69.8 18.3L72 359.2l-4.4-7c-18.5-29.4-28.2-63.3-28.2-98.2 0-101.7 82.8-184.5 184.6-184.5 49.3 0 95.6 19.2 130.4 54.1 34.8 34.9 56.2 81.2 56.1 130.5 0 101.8-84.9 184.6-186.6 184.6zm101.2-138.2c-5.5-2.8-32.8-16.2-37.9-18-5.1-1.9-8.8-2.8-12.5 2.8-3.7 5.6-14.3 18-17.6 21.8-3.2 3.7-6.5 4.2-12 1.4-32.6-16.3-54-29.1-75.5-66-5.7-9.8 5.7-9.1 16.3-30.3 1.8-3.7.9-6.9-.5-9.7-1.4-2.8-12.5-30.1-17.1-41.2-4.5-10.8-9.1-9.3-12.5-9.5-3.2-.2-6.9-.2-10.6-.2-3.7 0-9.7 1.4-14.8 6.9-5.1 5.6-19.4 19-19.4 46.3 0 27.3 19.9 53.7 22.6 57.4 2.8 3.7 39.1 59.7 94.8 83.8 35.2 15.2 49 16.5 66.6 13.9 10.7-1.6 32.8-13.4 37.4-26.4 4.6-13 4.6-24.1 3.2-26.4-1.3-2.5-5-3.9-10.5-6.6z"/>
        </svg>
      </span>
      <span class="ai-whatsapp-text-{{ ai_gen_id }}">
        {{ block.settings.button_text }}
      </span>
    </a>
  {% else %}
    <div style="padding: 20px; background-color: #f4f4f4; border-radius: 8px; text-align: center; color: #666;">
      Lütfen telefon numarası ekleyin
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "WhatsApp iletişim",
  "settings": [
    {
      "type": "header",
      "content": "İletişim bilgileri"
    },
    {
      "type": "text",
      "id": "phone_number",
      "label": "Telefon numarası",
      "info": "Ülke kodu ile birlikte girin (örn: 905551234567)"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Buton metni",
      "default": "WhatsApp ile iletişime geç"
    },
    {
      "type": "textarea",
      "id": "message",
      "label": "Ön tanımlı mesaj",
      "info": "İsteğe bağlı - Sohbeti başlatmak için otomatik mesaj"
    },
    {
      "type": "header",
      "content": "Stil ayarları"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Masaüstü genişlik",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "İkon boyutu",
      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "icon_text_gap",
      "label": "İkon ve metin arası boşluk",
      "min": 4,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 10
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Yazı boyutu",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Yazı kalınlığı",
      "options": [
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Orta"
        },
        {
          "value": "600",
          "label": "Kalın"
        },
        {
          "value": "700",
          "label": "Çok kalın"
        }
      ],
      "default": "500"
    },
    {
      "type": "range",
      "id": "button_padding",
      "label": "Buton iç boşluk",
      "min": 8,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Köşe yuvarlaklığı",
      "min": 0,
      "max": 50,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "border_width",
      "label": "Kenarlık kalınlığı",
      "min": 0,
      "max": 5,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Renkler"
    },
    {
      "type": "color",
      "id": "button_bg_color",
      "label": "Arka plan rengi",
      "default": "#25D366"
    },
    {
      "type": "color",
      "id": "button_hover_bg_color",
      "label": "Hover arka plan rengi",
      "default": "#128C7E"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Metin rengi",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_hover_color",
      "label": "Hover metin rengi",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Kenarlık rengi",
      "default": "#25D366"
    },
    {
      "type": "color",
      "id": "border_hover_color",
      "label": "Hover kenarlık rengi",
      "default": "#128C7E"
    }
  ],
  "presets": [
    {
      "name": "WhatsApp iletişim"
    }
  ]
}
{% endschema %}