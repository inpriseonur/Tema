          {{ section.settings.insta_img1 | image_url }} {{ block.settings.slider_img.width }}w
          "
          src="{{ section.settings.insta_img1 | image_url: width: 375 }}"
          data-src="{{ section.settings.insta_img1 | image_url: width: 375 }}"
          alt="{{ section.settings.insta_img1.alt | escape }}"
          class="img-fluid lazyload"
          width="{{ section.settings.insta_img1.width }}"
          height="{{ section.settings.insta_img1.width | divided_by: section.settings.insta_img1.aspect_ratio }}"
          decoding="async"
          loading="lazy">
        {%- else -%}
        {%- capture placeholder -%}product-apparel-{% cycle 1, 2, 3, 4 %}{%- endcapture -%}
        {{ placeholder | placeholder_svg_tag: 'placeholder-svg w-100 h-100' }}
        {%- endif -%}
