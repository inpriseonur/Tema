<section class="featured-highlights-section" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="container">
    <div class="featured-highlights">
      {%- for block in section.blocks -%}
        {%- if block.settings.title != blank or block.settings.text != blank -%}
          <div class="featured-highlights__item" {{ block.shopify_attributes }}>
            <span class="featured-highlights__icon featured-highlights__icon--{{ block.settings.tone }}" aria-hidden="true">
              {%- case block.settings.icon -%}
                {%- when 'tag' -%}
                  <i class="ti ti-tag"></i>
                {%- when 'package' -%}
                  <i class="ti ti-package"></i>
                {%- when 'truck' -%}
                  <i class="ti ti-truck"></i>
                {%- when 'card' -%}
                  <i class="ti ti-credit-card"></i>
                {%- when 'shield' -%}
                  <i class="ti ti-shield"></i>
                {%- when 'star' -%}
                  <i class="ti ti-star"></i>
                {%- else -%}
                  <i class="ti ti-check"></i>
              {%- endcase -%}
            </span>
            <span class="featured-highlights__content">
              {%- if block.settings.title != blank -%}
                <strong>{{ block.settings.title }}</strong>
              {%- endif -%}
              {%- if block.settings.text != blank -%}
                <span>{{ block.settings.text }}</span>
              {%- endif -%}
            </span>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} .featured-highlights {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns_desktop }}, minmax(0, 1fr));
    border: 1px solid {{ section.settings.border_color }};
    border-radius: {{ section.settings.border_radius }}px;
    overflow: hidden;
    background: {{ section.settings.background_color }};
  }

  #shopify-section-{{ section.id }} .featured-highlights__item {
    display: flex;
    align-items: center;
    gap: 12px;
    min-width: 0;
    padding: {{ section.settings.item_padding_y }}px {{ section.settings.item_padding_x }}px;
    border-right: 1px solid {{ section.settings.border_color }};
  }

  #shopify-section-{{ section.id }} .featured-highlights__item:last-child {
    border-right: 0;
  }

  #shopify-section-{{ section.id }} .featured-highlights__icon {
    width: {{ section.settings.icon_size }}px;
    height: {{ section.settings.icon_size }}px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 {{ section.settings.icon_size }}px;
  }

  #shopify-section-{{ section.id }} .featured-highlights__icon i {
    font-size: {{ section.settings.icon_font_size }}px;
    line-height: 1;
  }

  #shopify-section-{{ section.id }} .featured-highlights__icon--green {
    background: #eaf3de;
    color: #3b6d11;
  }

  #shopify-section-{{ section.id }} .featured-highlights__icon--blue {
    background: #e6f1fb;
    color: #185fa5;
  }

  #shopify-section-{{ section.id }} .featured-highlights__icon--gold {
    background: #faeeda;
    color: #854f0b;
  }

  #shopify-section-{{ section.id }} .featured-highlights__icon--gray {
    background: #f1f3f5;
    color: #4f5b6b;
  }

  #shopify-section-{{ section.id }} .featured-highlights__content {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }

  #shopify-section-{{ section.id }} .featured-highlights__content strong {
    display: block;
    font-size: {{ section.settings.title_size }}px;
    font-weight: 600;
    line-height: 1.25;
    color: {{ section.settings.title_color }};
  }

  #shopify-section-{{ section.id }} .featured-highlights__content span {
    display: block;
    font-size: {{ section.settings.text_size }}px;
    font-weight: 400;
    line-height: 1.3;
    color: {{ section.settings.text_color }};
  }

  @media (max-width: 767px) {
    #shopify-section-{{ section.id }} .featured-highlights {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    #shopify-section-{{ section.id }} .featured-highlights__item {
      gap: 9px;
      padding: {{ section.settings.mobile_item_padding_y }}px {{ section.settings.mobile_item_padding_x }}px;
      border-right: 1px solid {{ section.settings.border_color }};
      border-bottom: 1px solid {{ section.settings.border_color }};
    }

    #shopify-section-{{ section.id }} .featured-highlights__item:nth-child(2n) {
      border-right: 0;
    }

    #shopify-section-{{ section.id }} .featured-highlights__item:nth-last-child(-n+2) {
      border-bottom: 0;
    }

    #shopify-section-{{ section.id }} .featured-highlights__icon {
      width: {{ section.settings.mobile_icon_size }}px;
      height: {{ section.settings.mobile_icon_size }}px;
      flex-basis: {{ section.settings.mobile_icon_size }}px;
    }

    #shopify-section-{{ section.id }} .featured-highlights__icon i {
      font-size: {{ section.settings.mobile_icon_font_size }}px;
    }

    #shopify-section-{{ section.id }} .featured-highlights__content strong {
      font-size: {{ section.settings.mobile_title_size }}px;
    }

    #shopify-section-{{ section.id }} .featured-highlights__content span {
      font-size: {{ section.settings.mobile_text_size }}px;
    }
  }
</style>

