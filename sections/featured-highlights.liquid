<section class="featured-highlights-section" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="container">
    <div class="featured-highlights">
      {%- for block in section.blocks -%}
        {%- if block.settings.title != blank or block.settings.text != blank -%}
          {%- assign faq_target = block.settings.faq_target | strip -%}
          <div
            class="featured-highlights__item{% if faq_target != blank %} featured-highlights__item--clickable{% endif %}"
            {% if faq_target != blank %}
              role="button"
              tabindex="0"
              data-featured-highlight-target="{{ faq_target | escape }}"
            {% endif %}
            {{ block.shopify_attributes }}
          >
            <span class="featured-highlights__icon featured-highlights__icon--{{ block.settings.tone }}" aria-hidden="true">
              {%- case block.settings.icon -%}
                {%- when 'tag' -%}
                  <i class="ti ti-tag"></i>
                {%- when 'package' -%}
                  <i class="ti ti-package"></i>
                {%- when 'truck' -%}
                  <i class="ti ti-truck"></i>
                {%- when 'card' -%}
                  <i class="ti ti-credit-card"></i>
                {%- when 'shield' -%}
                  <i class="ti ti-shield"></i>
                {%- when 'star' -%}
                  <i class="ti ti-star"></i>
                {%- else -%}
                  <i class="ti ti-check"></i>
              {%- endcase -%}
            </span>
            <span class="featured-highlights__content">
              {%- if block.settings.title != blank -%}
                <strong>{{ block.settings.title }}</strong>
              {%- endif -%}
              {%- if block.settings.text != blank -%}
                <span>{{ block.settings.text }}</span>
              {%- endif -%}
            </span>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} .featured-highlights {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns_desktop }}, minmax(0, 1fr));
    border: 1px solid {{ section.settings.border_color }};
    border-radius: {{ section.settings.border_radius }}px;
    overflow: hidden;
    background: {{ section.settings.background_color }};
  }

  #shopify-section-{{ section.id }} .featured-highlights__item {
    display: flex;
    align-items: center;
    gap: 12px;
    min-width: 0;
    padding: {{ section.settings.item_padding_y }}px {{ section.settings.item_padding_x }}px;
    border-right: 1px solid {{ section.settings.border_color }};
  }

  #shopify-section-{{ section.id }} .featured-highlights__item--clickable {
    cursor: pointer;
    transition: background-color 0.18s ease, transform 0.18s ease, box-shadow 0.18s ease;
  }

  #shopify-section-{{ section.id }} .featured-highlights__item--clickable .featured-highlights__icon {
    transition: transform 0.18s ease, box-shadow 0.18s ease;
  }

  #shopify-section-{{ section.id }} .featured-highlights__item--clickable:focus-visible {
    outline: 2px solid #c9a063;
    outline-offset: -2px;
  }

  @media (min-width: 768px) {
    #shopify-section-{{ section.id }} .featured-highlights__item--clickable:hover {
      background: rgba(201, 160, 99, 0.06);
      box-shadow: inset 0 -2px 0 rgba(201, 160, 99, 0.35);
      transform: translateY(-1px);
    }

    #shopify-section-{{ section.id }} .featured-highlights__item--clickable:hover .featured-highlights__icon {
      transform: scale(1.04);
      box-shadow: 0 4px 12px rgba(6, 31, 79, 0.08);
    }
  }

  #shopify-section-{{ section.id }} .featured-highlights__item:last-child {
    border-right: 0;
  }

  #shopify-section-{{ section.id }} .featured-highlights__icon {
    width: {{ section.settings.icon_size }}px;
    height: {{ section.settings.icon_size }}px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 {{ section.settings.icon_size }}px;
  }

  #shopify-section-{{ section.id }} .featured-highlights__icon i {
    font-size: {{ section.settings.icon_font_size }}px;
    line-height: 1;
  }

  #shopify-section-{{ section.id }} .featured-highlights__icon--green {
    background: #eaf3de;
    color: #3b6d11;
  }

  #shopify-section-{{ section.id }} .featured-highlights__icon--blue {
    background: #e6f1fb;
    color: #185fa5;
  }

  #shopify-section-{{ section.id }} .featured-highlights__icon--gold {
    background: #faeeda;
    color: #854f0b;
  }

  #shopify-section-{{ section.id }} .featured-highlights__icon--gray {
    background: #f1f3f5;
    color: #4f5b6b;
  }

  #shopify-section-{{ section.id }} .featured-highlights__content {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }

  #shopify-section-{{ section.id }} .featured-highlights__content strong {
    display: block;
    font-size: {{ section.settings.title_size }}px;
    font-weight: 600;
    line-height: 1.25;
    color: {{ section.settings.title_color }};
  }

  #shopify-section-{{ section.id }} .featured-highlights__content span {
    display: block;
    font-size: {{ section.settings.text_size }}px;
    font-weight: 400;
    line-height: 1.3;
    color: {{ section.settings.text_color }};
  }

  @media (max-width: 767px) {
    #shopify-section-{{ section.id }} .featured-highlights {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    #shopify-section-{{ section.id }} .featured-highlights__item {
      gap: 9px;
      padding: {{ section.settings.mobile_item_padding_y }}px {{ section.settings.mobile_item_padding_x }}px;
      border-right: 1px solid {{ section.settings.border_color }};
      border-bottom: 1px solid {{ section.settings.border_color }};
    }

    #shopify-section-{{ section.id }} .featured-highlights__item:nth-child(2n) {
      border-right: 0;
    }

    #shopify-section-{{ section.id }} .featured-highlights__item:nth-last-child(-n+2) {
      border-bottom: 0;
    }

    #shopify-section-{{ section.id }} .featured-highlights__icon {
      width: {{ section.settings.mobile_icon_size }}px;
      height: {{ section.settings.mobile_icon_size }}px;
      flex-basis: {{ section.settings.mobile_icon_size }}px;
    }

    #shopify-section-{{ section.id }} .featured-highlights__icon i {
      font-size: {{ section.settings.mobile_icon_font_size }}px;
    }

    #shopify-section-{{ section.id }} .featured-highlights__content strong {
      font-size: {{ section.settings.mobile_title_size }}px;
    }

    #shopify-section-{{ section.id }} .featured-highlights__content span {
      font-size: {{ section.settings.mobile_text_size }}px;
    }

    {% unless section.settings.enable_mobile_links %}
      #shopify-section-{{ section.id }} .featured-highlights__item--clickable {
        cursor: default;
      }
    {% endunless %}
  }
</style>

<script>
  (() => {
    const section = document.getElementById('shopify-section-{{ section.id }}');
    if (!section) return;

    const mobileLinksEnabled = {{ section.settings.enable_mobile_links | json }};
    const normalizeTarget = (value) => {
      if (!value) return '';
      const target = value.trim();
      return target.charAt(0) === '#' ? target : `#${target}`;
    };

    const openFaqTarget = (trigger) => {
      if (!mobileLinksEnabled && window.matchMedia('(max-width: 767px)').matches) return;

      const selector = normalizeTarget(trigger.dataset.featuredHighlightTarget);
      if (!selector) return;

      const collapse = document.querySelector(selector);
      if (!collapse) return;

      const control = document.querySelector(`[href="${selector}"], [data-bs-target="${selector}"]`);
      if (control && window.bootstrap && window.bootstrap.Collapse) {
        window.bootstrap.Collapse.getOrCreateInstance(collapse, { toggle: false }).show();
        control.setAttribute('aria-expanded', 'true');
      } else {
        collapse.classList.add('show');
        if (control) control.setAttribute('aria-expanded', 'true');
      }

      const focusTarget = control || collapse;
      const offset = window.matchMedia('(max-width: 767px)').matches ? 72 : 110;
      const top = focusTarget.getBoundingClientRect().top + window.pageYOffset - offset;
      window.scrollTo({ top, behavior: 'smooth' });

      window.setTimeout(() => {
        focusTarget.setAttribute('tabindex', '-1');
        focusTarget.focus({ preventScroll: true });
      }, 280);
    };

    section.querySelectorAll('[data-featured-highlight-target]').forEach((item) => {
      item.addEventListener('click', () => openFaqTarget(item));
      item.addEventListener('keydown', (event) => {
        if (event.key !== 'Enter' && event.key !== ' ') return;
        event.preventDefault();
        openFaqTarget(item);
      });
    });
  })();
</script>

