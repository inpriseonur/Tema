<style>
.blog-section {
  padding-top: {{ section.settings.section_padding_top }}px;
  padding-bottom: {{ section.settings.section_padding_bottom }}px;
  {% if section.settings.section_bgcolor_enable %}
  background-color: {{ section.settings.section_bgcolor }};
  {% endif %}
}
@media (max-width: 1199px) {
  .blog-section {
    padding-top: {{ section.settings.section_padding_top_ip }}px;
    padding-bottom: {{ section.settings.section_padding_bottom_ip }}px;
  }
}
@media (max-width: 767px) {
  .blog-section {
    padding-top: {{ section.settings.section_padding_top_xs }}px;
    padding-bottom: {{ section.settings.section_padding_bottom_xs }}px;
  }
}
{% if section.settings.sidebar_handle == 'left_sidebar_handle' or section.settings.sidebar_handle == 'right_sidebar_handle' %}
.blog-section .blog-wrap {
  display: flex;
  flex-wrap: wrap;
  {% if section.settings.sidebar_handle == 'right_sidebar_handle' %}
  flex-direction: row-reverse;
  {% endif %}
  margin: -30px 0px 0px -30px;
}
.blog-section .blog-wrap .sidebar-wrapper {
  margin: 30px 0px 0px 30px;
  width: 100%;
}
{% if section.settings.sidebar_handle == 'left_sidebar_handle' or section.settings.sidebar_handle == 'right_sidebar_handle' %}
.blog-section .blog-wrap .sidebar-wrapper.blog-article {
  width: calc(75% - 30px);
}
.blog-section .blog-wrap .sidebar-wrapper.blog-sidebar {
  width: calc(25% - 30px);
}
@media (max-width: 1199px) {
  .blog-section .blog-wrap {
    margin: -30px 0px 0px -30px;
  }
  .blog-section .blog-wrap .sidebar-wrapper {
    margin: 30px 0px 0px 30px;
  }
  .blog-section .blog-wrap .sidebar-wrapper.blog-article {
    width: calc(66.67% - 30px);
  }
  .blog-section .blog-wrap .sidebar-wrapper.blog-sidebar {
    width: calc(33.33% - 30px);
  }
}
@media (max-width: 991px) {
  .blog-section .blog-wrap {
    flex-direction: column-reverse;
  }
  {% if section.settings.sidebar_handle == 'right_sidebar_handle' %}
  .blog-content-wrap .blog-grid-wrapper {
    flex-direction: column;
  }
  {% endif %}
  .blog-section .blog-wrap .sidebar-wrapper.blog-article,
  .blog-section .blog-wrap .sidebar-wrapper.blog-sidebar {
    width: calc(100% - 30px);
  }
  .blog-section .blog-wrap .sidebar-wrapper.blog-sidebar {
    margin-top: 60px;
  }
}
{% endif %}
@media (max-width: 767px) {
  .blog-section .blog-wrap {
    {% if settings.enable_rtl %}
    margin: -30px -12px 0px 0px;
    {% else %}
    margin: -30px 0px 0px -12px;
    {% endif %}
  }
  .blog-section .blog-wrap .sidebar-wrapper {
    {% if settings.enable_rtl %}
    margin: 30px 12px 0px 0px;
    {% else %}
    margin: 30px 0px 0px 12px;
    {% endif %}
  }
  {% if section.settings.sidebar_handle == 'left_sidebar_handle' or section.settings.sidebar_handle == 'right_sidebar_handle' %}
  .blog-section .blog-wrap .sidebar-wrapper.blog-article,
  .blog-section .blog-wrap .sidebar-wrapper.blog-sidebar {
    width: calc(100% - 12px);
  }
  {% endif %}
}
{% endif %}

.blog-section ul.single-blog-area {
  display: flex;
  flex-wrap: wrap;
  margin: -30px 0px 0px -30px;
}
.blog-section ul.single-blog-area li.blog-slider {
  position: relative;
  margin: 30px 0px 0px 30px;
}

{% if section.settings.blog_news_column == '4' %}
.blog-section ul.single-blog-area li.blog-slider{
  width: calc(25% - 30px);
}
@media (max-width: 1199px){
  .blog-section ul.single-blog-area li.blog-slider{
    width: calc(33.33% - 30px);
  }
}
@media (max-width: 991px){
  .blog-section ul.single-blog-area li.blog-slider{
    width: calc(50% - 30px);
  }
}
{% endif %}

{% if section.settings.blog_news_column == '3' %}
.blog-section ul.single-blog-area li.blog-slider{
  width: calc(33.33% - 30px);
}
@media (max-width: 1199px){
  .blog-section ul.single-blog-area li.blog-slider{
    width: calc(50% - 30px);
  }
}
@media (max-width: 991px){
  .blog-section ul.single-blog-area li.blog-slider{
    width: calc(50% - 30px);
  }
}
{% endif %}
{% if section.settings.blog_news_column == '2' %}
.blog-section ul.single-blog-area li.blog-slider{
  width: calc(50% - 30px);
}
@media (max-width: 1199px){
  .blog-section ul.single-blog-area li.blog-slider{
    width: calc(50% - 30px);
  }
}
@media (max-width: 991px){
  .blog-section ul.single-blog-area li.blog-slider{
    width: calc(50% - 30px);
  }
}
{% endif %}
@media (max-width : 767px){
  .blog-section ul.single-blog-area{
    margin: -30px 0px 0px -12px;
  }
  .blog-section ul.single-blog-area li.blog-slider{
    width: calc(50% - 12px);
    margin: 30px 0px 0px 12px;
  }
}
@media (max-width: 600px) {
  .blog-section ul.single-blog-area li.blog-slider{
    width: calc(100% - 12px);
  }
}
</style>