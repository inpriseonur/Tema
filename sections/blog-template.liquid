<section class="blog-section">
  <div class="container">
    <div class="row">
      <div class="col">
        <div class="blog-wrap">
          {%- unless section.settings.sidebar_handle == 'without_sidebar' -%}
          <div class="sidebar-wrapper blog-sidebar">
            {% render 'blog-sidebar' %}
          </div>
          {%- endunless -%}
          <div class="sidebar-wrapper blog-article">
            {%- assign blogs_limit = section.settings.blog_news_limit_handle -%}
            {%- paginate blog.articles by blogs_limit -%}
              <ul class="single-blog-area">
                {% for article in blog.articles %}
                <li class="blog-slider">
                  {% render 'blog-grid-item', article: article %}
                </li>
                {% endfor %}
              </ul>
              {% if paginate.pages > 1 %}
              <div class="paginatoin-area">
                <ul class="paginate">
                  <li class="page-numerous">
                    {%- render 'pagination', paginate: paginate -%}
                  </li>
                </ul>
              </div>
              {% endif %}
            {%- endpaginate -%}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
