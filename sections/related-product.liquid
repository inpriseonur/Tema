<section class="related-product">
  <div class="container">
    <div class="row">
      <div class="col">
        <div class="product-related">
          <div class="section-title">
            {% if section.settings.related_title !='' %}
            <h2 class="heading-home">{{ section.settings.related_title }}</h2>
            {% endif %}
          </div>
          <relative-pro class="related-slider isolate" data-url="{{ routes.product_recommendations_url }}?section_id={{ section.id }}&product_id={{ product.id }}&limit={{ section.settings.products_to_show }}">
            {% if recommendations.performed and recommendations.products_count > 0 %}
            <div class="product-related-slider swiper" id="related-slider" data-slides-per-view="{{ section.settings.product_view }}"slide-view="5">
              <div class="swiper-wrapper">
                {% for recommendation in recommendations.products %}
                <div class="swiper-slide">
                  {% render 'product-grid-item', product: recommendation %}
                </div>
                {% endfor %}
              </div>
            </div>
            {% endif %}
          </relative-pro>
        </div>
      </div>
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Related Product",
  "settings": [
  {
      "type": "header",
      "content": "Section Padding"
  },
  {
      "type": "range",
      "id": "section_padding_top",
      "label": "Section Padding Top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 80
  },
  {
      "type": "range",
      "id": "section_padding_bottom",
      "label": "Section Padding Bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 80
  },
  {
      "type" : "paragraph",
      "content" : "Mobile"
  },
  {
      "type": "range",
      "id": "section_padding_top_xs",
      "label": "Section Padding Top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 50
  },
  {
      "type": "range",
      "id": "section_padding_bottom_xs",
      "label": "Section Padding Bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 50
  },
  {
    "type": "text",
    "id": "related_title",
    "label": "Section Title",
    "default": "Related Product"
  },
  {
    "type": "header",
    "content": "Product Options"
  },
  {
    "type": "text",
    "id": "products_to_show",
    "label": "Product Limit",
    "default": "8"
  }
  ]
}
{% endschema %}
<style>
  .related-product {
    padding-top: {{ section.settings.section_padding_top }}px;
    padding-bottom: {{ section.settings.section_padding_bottom }}px;
  }

  .related-product .section-title h2 {
    text-transform: none;
  }

  .related-product .single-product-wrap .product-content {
    text-align: left;
  }

  .related-product .single-product-wrap .product-content .product-title a {
    display: -webkit-box;
    height: 39px;
    overflow: hidden;
    color: #061f4f;
    font-size: 14px;
    font-weight: 600;
    line-height: 1.38;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  .related-product .single-product-wrap .product-content .price-box {
    margin-top: 7px;
    line-height: 1.1;
  }

  .related-product .single-product-wrap .price-box .new-price {
    color: var(--color-secondary);
    font-size: 20px;
    font-weight: 700;
    line-height: 1.1;
  }

  .related-product .single-product-wrap .price-box .old-price {
    color: #8f8f8f;
    font-size: 13px;
    line-height: 1.1;
  }

  .related-product .single-product-wrap .product-image .product-label .sale-title {
    min-width: 40px;
    padding: 4px 9px;
    border-radius: 4px;
    font-size: 12px;
    font-weight: 700;
    line-height: 1.1;
    text-align: center;
  }

  @media (min-width: 1200px) {
    .related-product .section-title h2 {
      font-size: 24px;
      margin-bottom: 22px;
    }

    .related-product .single-product-wrap .product-image {
      width: 80%;
      margin-left: auto;
      margin-right: auto;
    }
  }

  @media(max-width: 1199px){
    .related-product {
      padding-top: {{ section.settings.section_padding_top_xs }}px;
      padding-bottom: {{ section.settings.section_padding_bottom_xs }}px;
    }
  }

  @media(max-width: 767px){
    .related-product .single-product-wrap .product-content .product-title a {
      height: 38px;
      font-size: 13px;
      line-height: 1.45;
    }

    .related-product .single-product-wrap .price-box .new-price {
      font-size: 18px;
    }

    .related-product .single-product-wrap .price-box .old-price {
      display: block;
      margin-top: 3px;
      padding-left: 0;
      font-size: 12px;
    }

    .related-product .single-product-wrap .product-image .product-label .sale-title {
      min-width: 36px;
      padding: 3px 8px;
      font-size: 11px;
    }
  }
</style>




