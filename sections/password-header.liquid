<div class="password-header">
  {%- if section.settings.logo_header -%}
  <a href="{{ shop.url }}" class="theme-header-logo" style="max-width: {{ section.settings.logo_header_max_width }}px;">
    {% if section.settings.logo_header.src != blank %}
    {{ section.settings.logo_header.src | image_url: width: 500 | image_tag:
      loading: 'lazy',
      width: section.settings.logo_header.width,
      height: section.settings.logo_header.height,
      class: "img-fluid lazyload main-logo",
      alt: shop.name | escape }}
    {% endif %}
    </a>
  {%- else -%}
  <a href="{{ shop.url }}" class="theme-header-logo">
    <span>{{ shop.name }}</span>
  </a>
  {%- endif -%}
  <span class="password-coming-soon">{{ section.settings.pwd_heder_soon_title }}</span>
</div>
{% schema %}
{
  "name": "Password Header",
  "settings": [
    {
      "type": "header",
      "content": "Section Content"
    },
    {
      "type": "range",
      "id": "logo_header_max_width",
      "min": 10,
      "max": 300,
      "step": 5,
      "unit": "px",
      "label": "Logo Width",
      "default": 120
    },
    {
      "type": "image_picker",
      "id": "logo_header",
      "label": "Logo Image",
      "info": "Recommended Size: 107px x 26px"
    },
    {
      "type": "text",
      "id": "pwd_heder_soon_title",
      "label": "Title",
      "default": "Coming soon"
    }
  ]
}
{% endschema %}
<style>
  .password-header a.theme-header-logo img,
  .password-header a.theme-header-logo {
    margin: 0 auto;
  }
  .password-header span.password-coming-soon{
    display: block;
    color: var(--font-color-body);
    font-size: 30px;
    margin-top: 19px;
    text-transform: uppercase;
    font-weight: 400;
    letter-spacing: 5px;
  }
  @media (max-width: 479px) {
    .password-header span.password-coming-soon{
      font-size: 20px;
      margin-top: 21px;
      letter-spacing: 3px;
    }
  }
</style>
