{% comment %}
  Renders a single complementary product recommendation.
  Fetched via: /recommendations/products?section_id=cart-complementary&product_id=XXX&limit=1&intent=complementary
{% endcomment %}

{% if recommendations.performed and recommendations.products_count > 0 %}
  {% assign rec_product = recommendations.products.first %}
  {% assign rec_variant = rec_product.selected_or_first_available_variant %}

  <div class="cart-complementary-product">
    <h6 class="cart-complementary-product__heading">Sepetini tamamla</h6>
    <div class="cart-complementary-product__item">
      {% if rec_product.featured_image %}
      <a href="{{ rec_product.url }}" class="cart-complementary-product__img">
        <img
          src="{{ rec_product.featured_image | image_url: width: 150 }}"
          alt="{{ rec_product.title | escape }}"
          loading="lazy"
          width="60"
          height="60"
          style="border-radius:8px; object-fit:cover;">
      </a>
      {% endif %}
      <div class="cart-complementary-product__info">
        <a href="{{ rec_product.url }}" class="cart-complementary-product__name">
          {{ rec_product.title | truncate: 45 }}
        </a>
        <div class="cart-complementary-product__price">
          <span class="new-price">{{ rec_variant.price | money }}</span>
          {% if rec_product.compare_at_price_max > rec_product.price %}
            <span class="old-price">{{ rec_variant.compare_at_price | money }}</span>
          {% endif %}
        </div>
      </div>
      <button
        type="button"
        class="cart-complementary-product__add-btn"
        data-variant-id="{{ rec_variant.id }}"
        data-qty="{{ rec_variant.quantity_rule.min | default: 1 }}"
        {% unless rec_variant.available %}disabled{% endunless %}
        aria-label="{{ 'products.product.add_to_cart' | t }}: {{ rec_product.title | escape }}">
        {% if rec_variant.available %}
          <i class="fa fa-plus"></i>
        {% else %}
          <i class="fa fa-ban"></i>
        {% endif %}
      </button>
    </div>
  </div>

  <style>
    .cart-complementary-product {
      padding: 14px 15px 12px;
      border-top: 1px dashed #dfe3ea;
    }
    .cart-complementary-product__heading {
      font-size: 12px;
      font-weight: 700;
      margin: 0 0 10px 0;
      color: #061f4f;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    .cart-complementary-product__item {
      display: flex;
      align-items: center;
      gap: 12px;
      background: #fff;
      border: 1px solid #edf0f4;
      border-radius: 8px;
      padding: 10px;
      box-shadow: 0 4px 16px rgba(16, 24, 40, 0.04);
    }
    .cart-complementary-product__img {
      flex-shrink: 0;
      width: 55px;
      height: 55px;
      padding: 3px;
      border: 1px solid #edf0f4;
      border-radius: 6px;
      background: #fff;
    }
    .cart-complementary-product__img img {
      width: 100%;
      height: 100%;
      object-fit: contain;
      border-radius: 4px;
    }
    .cart-complementary-product__info {
      flex: 1;
      min-width: 0;
    }
    .cart-complementary-product__name {
      display: block;
      font-size: 13px;
      font-weight: 700;
      color: #061f4f;
      line-height: 1.3;
      text-decoration: none;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .cart-complementary-product__name:hover {
      color: #061f4f;
    }
    .cart-complementary-product__price {
      margin-top: 3px;
      display: flex;
      align-items: center;
      gap: 6px;
    }
    .cart-complementary-product__price .new-price {
      font-size: 13px;
      font-weight: 700;
      color: #061f4f;
    }
    .cart-complementary-product__price .old-price {
      font-size: 11px;
      text-decoration: line-through;
      color: #999;
    }
    .cart-complementary-product__add-btn {
      flex-shrink: 0;
      width: 38px;
      height: 38px;
      border-radius: 50%;
      border: 1px solid #061f4f;
      background: #fff;
      color: #061f4f;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 14px;
      transition: all 0.25s ease;
    }
    .cart-complementary-product__add-btn:hover:not(:disabled) {
      background: #061f4f;
      color: #fff;
      box-shadow: inset 0 -2px 0 rgba(218, 177, 90, 0.72);
    }
    .cart-complementary-product__add-btn:disabled {
      border-color: #ccc;
      color: #ccc;
      cursor: not-allowed;
    }
  </style>
{% endif %}
