<section class="new-product">
  <div class="container">
    <div class="row">
      <div class="col-xl-12 col-lg-12 col-md-12">
        <div class="section-title">
          {% if section.settings.section_title !='' %}
          <h2>{{ section.settings.section_title }}</h2>
          {% endif %}
        </div>
        {% assign category_product = collections[section.settings.label_product] %}
        <div class="new-product-slider owl-carousel" id="new-pro-{{ section.id }}">
          {% assign category_product_limit = section.settings.category_product_limit_handle %}
          {% for product in category_product.products limit: category_product_limit %}
          <div class="item">
            {% include 'product-grid-item' %}
          </div>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</section>
<script type="text/javascript">
addEventListener('DOMContentLoaded', (event) => {
  $('#new-pro-{{ section.id }}').owlCarousel({
    rewind: true,
    margin: 30,
    items: 4,
    nav: true,
    navText: ['<i class="fa fa-angle-left"></i>','<i class="fa fa-angle-right"></i>'],
    dots: false,
    {%- if settings.enable_rtl -%}
    rtl: true,
    {%- endif -%}
    loop: {{ section.settings.loop }},
    autoplay: {{ section.settings.autoplay }},
    autoplayTimeout: {{ section.settings.autoplay_time }},
    autoplayHoverPause: true,
    responsive:{
        0:{
          items: 1,
          margin: 12
        },
        320:{
          items: 2,
          margin: 12
        },
        479:{
          items: 2,
          margin: 12
        },
        540:{
          items: 2,
           margin: 12
        },
        768:{
          items: 2
        },
        979:{
          items: 3
        },
        1199:{
          items: 4
        },
        1599:{
          items: 4
        }
      }
  });
});
</script>

{% schema %}
{
  "name": "New product",
  "settings": [
  {
      "type": "header",
      "content": "Section Padding"
  },
  {
      "type": "range",
      "id": "section_padding_top",
      "label": "Section Padding Top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 80
  },
  {
      "type": "range",
      "id": "section_padding_bottom",
      "label": "Section Padding Bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 80
  },
  {
      "type" : "paragraph",
      "content" : "Mobile"
  },
  {
      "type": "range",
      "id": "section_padding_top_xs",
      "label": "Section Padding Top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 50
  },
  {
      "type": "range",
      "id": "section_padding_bottom_xs",
      "label": "Section Padding Bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 50
  },
  {
    "type": "text",
    "id": "section_title",
    "label": "Section title",
    "default": "Trending products"
  },
  {
    "type": "text",
    "id": "category_product_limit_handle",
    "label": "Product Limit",
    "default": "10"
  },
  {
    "type" : "collection",
    "id" : "label_product",
    "label" : "New Product"
  },
  {
    "type": "header",
    "content": "slider settings"
  },
  {
    "type": "checkbox",
    "id": "loop",
    "label": "Slider loop",
    "default": true
  },
  {
    "type": "checkbox",
    "id": "autoplay",
    "label": "Slider autoplay",
    "default": true
  },
  {
    "type": "number",
    "id": "autoplay_time",
    "label": "Slider timer out",
    "default": 5000
  }
  ],
  "presets":[
  {
    "name": "New product"
  }
  ]
}
{% endschema %}
<style>
.new-product {
    padding-top: {{ section.settings.section_padding_top }}px;
    padding-bottom: {{ section.settings.section_padding_bottom }}px;
}
@media(max-width: 1199px) {
    .new-product {
        padding-top: {{ section.settings.section_padding_top_xs }}px;
        padding-bottom: {{ section.settings.section_padding_bottom_xs }}px;
    }
}

.new-product .new-product-slider .owl-nav{
    margin-top: 0;
}
.new-product .new-product-slider .item {
    height: 100%;
}
.new-product .new-product-slider .single-product-wrap {
    display: flex;
    flex-direction: column;
    height: 100%;
}
.new-product .new-product-slider .single-product-wrap .product-image {
    width: 100%;
}
.new-product .new-product-slider .single-product-wrap .product-image .ratio {
    --ratio-percent: 88% !important;
}
.new-product .new-product-slider .single-product-wrap .product-image .ratio img {
    object-fit: contain;
}
.new-product .new-product-slider .single-product-wrap .product-content {
    margin-top: 12px;
    text-align: left;
}
.new-product .new-product-slider .single-product-wrap .product-content .product-title a {
    display: -webkit-box;
    height: 39px;
    overflow: hidden;
    color: #061f4f;
    font-size: 14px;
    font-weight: 600;
    line-height: 1.38;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
}
.new-product .new-product-slider .single-product-wrap .product-content .price-box {
    margin-top: 7px;
    line-height: 1.1;
}
.new-product .new-product-slider .single-product-wrap .price-box .new-price {
    color: var(--color-secondary);
    font-size: 20px;
    font-weight: 700;
    line-height: 1.1;
}
.new-product .new-product-slider .single-product-wrap .price-box .old-price {
    color: #8f8f8f;
    font-size: 13px;
    line-height: 1.1;
}
.new-product .new-product-slider .single-product-wrap .product-image .product-label .sale-title {
    min-width: 40px;
    padding: 4px 9px;
    border-radius: 4px;
    font-size: 12px;
    font-weight: 700;
    line-height: 1.1;
    text-align: center;
}
.new-product .new-product-slider .owl-nav button{
    position: absolute;
    bottom: 50%;
    transform: translateY(50%);
    margin: 0;
    line-height: 0;
    font-size: 18px;
    height: 28px;
    width: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(6, 31, 79, 0.16);
    border-radius: 4px;
    color: var(--color-primary);
    background-color: rgba(255, 255, 255, 0.92);
    box-shadow: 0px 4px 12px rgba(6, 31, 79, 0.08);
    -webkit-transition: all 0.2s ease-in-out 0s;
    -o-transition: all 0.2s ease-in-out 0s;
    transition: all 0.2s ease-in-out 0s;
}
.new-product .new-product-slider .owl-nav button:hover {
    color: #fff;
    border-color: var(--color-primary);
    background-color: var(--color-primary);
    box-shadow: 0px 6px 16px rgba(6, 31, 79, 0.12);
}
.new-product .new-product-slider .owl-nav button.owl-prev{
    left: -15px;
}
.new-product .new-product-slider .owl-nav button.owl-next{
    right: -15px;
}
@media(max-width: 767px) {
    .new-product .new-product-slider .single-product-wrap .product-image .ratio {
        --ratio-percent: 82% !important;
    }
    .new-product .new-product-slider .single-product-wrap .product-content {
        margin-top: 10px;
    }
    .new-product .new-product-slider .single-product-wrap .product-content .product-title a {
        height: 38px;
        font-size: 13px;
        line-height: 1.45;
    }
    .new-product .new-product-slider .single-product-wrap .price-box .new-price {
        font-size: 18px;
    }
    .new-product .new-product-slider .single-product-wrap .price-box .old-price {
        display: block;
        margin-top: 3px;
        padding-left: 0;
        font-size: 12px;
    }
    .new-product .new-product-slider .single-product-wrap .product-image .product-label .sale-title {
        min-width: 36px;
        padding: 3px 8px;
        font-size: 11px;
    }
    .new-product .new-product-slider .owl-nav button {
        height: 26px;
        width: 26px;
        font-size: 16px;
    }
    .new-product .new-product-slider .owl-nav button.owl-prev {
        left: -10px;
    }
    .new-product .new-product-slider .owl-nav button.owl-next {
        right: -10px;
    }
}
</style>
