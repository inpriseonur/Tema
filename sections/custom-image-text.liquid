<section class="home-about-area">
	<div class="container">
		<div class="row">
			<div class="col">
				<div class="about-area {% if section.settings.show_row_reverse %} row-reverse {% endif %}">
					<div class="about-image">
						{%- if section.settings.home_about_image -%}
						<img srcset="
						{%- if section.settings.home_about_image.width >= 375 -%}{{ section.settings.home_about_image | image_url: width: 375 }} 375w,{%- endif -%}
						{%- if section.settings.home_about_image.width >= 550 -%}{{ section.settings.home_about_image | image_url: width: 550 }} 550w,{%- endif -%}
						{%- if section.settings.home_about_image.width >= 750 -%}{{ section.settings.home_about_image | image_url: width: 750 }} 750w,{%- endif -%}
						{%- if section.settings.home_about_image.width >= 1100 -%}{{ section.settings.home_about_image | image_url: width: 1100 }} 1100w,{%- endif -%}
						{%- if section.settings.home_about_image.width >= 1500 -%}{{ section.settings.home_about_image | image_url: width: 1500 }} 1500w,{%- endif -%}
						{%- if section.settings.home_about_image.width >= 1780 -%}{{ section.settings.home_about_image | image_url: width: 1780 }} 1780w,{%- endif -%}
						{%- if section.settings.home_about_image.width >= 2000 -%}{{ section.settings.home_about_image | image_url: width: 2000 }} 2000w,{%- endif -%}
						{{ section.settings.home_about_image | image_url }} {{ section.settings.home_about_image.width }}w
						"
						src="{{ section.settings.home_about_image | image_url: width: 2000 }}"
						data-src="{{ section.settings.home_about_image | image_url: width: 2000 }}"
						alt="{{ section.settings.home_about_image.alt | escape }}"
						class="img-fluid lazyload"
						width="{{ section.settings.home_about_image.width }}"
						height="{{ section.settings.home_about_image.width | divided_by: section.settings.home_about_image.aspect_ratio }}"
						decoding="async"
						loading="lazy"
						sizes="100vw">
						{%- else -%}
						{%- capture placeholder -%}hero-apparel-{% cycle 1, 2, 3 %}{%- endcapture -%}
						{{ placeholder | placeholder_svg_tag: 'placeholder-svg' }}
						{%- endif -%}
					</div>
					<div class="about-content">
						{% if section.settings.about_subtitle != '' %}
						<span class="subtitle" style="color: {{ section.settings.about_subtitle_color }}">{{ section.settings.about_subtitle }}</span>
						{% endif %}
						<h2 class="title" style="color: {{ section.settings.about_title_color }}">
							<span>{{ section.settings.about_title_1 }}</span>
							<span>{{ section.settings.about_title_2 }}</span>
						</h2>
						{% if section.settings.about_desc != '' %}
						<p class="desc">{{ section.settings.about_desc }}</p>
						{% endif %}
						{% if section.settings.about_btn_text != '' %}
						<a href="{{ section.settings.about_url }}" class="btn-style1">{{ section.settings.about_btn_text }}</a>
						{% endif %}
					</div>
				</div>
			</div>
		</div>
	</div>
</section>
{% schema %}
{
	"name": "Custom Image & Text",
	"settings": [
	{
		"type" : "header",
		"content" : "Section Padding"
	},
	{
		"type" : "paragraph",
		"content" : "Desktop / Laptop / tablet"
	},
	{
		"type": "range",
		"id": "section_padding_top",
		"label": "Section Padding Top",
		"min": 0,
		"max": 100,
		"step": 5,
		"unit": "px",
		"default": 100
	},
	{
		"type": "range",
		"id": "section_padding_bottom",
		"label": "Section Padding Bottom",
		"min": 0,
		"max": 100,
		"step": 5,
		"unit": "px",
		"default": 100
	},
	{
		"type" : "paragraph",
		"content" : "Ipad pro / Ipad"
	},
	{
		"type": "range",
		"id": "section_padding_top_ipad",
		"label": "Section Padding Top",
		"min": 0,
		"max": 100,
		"step": 5,
		"unit": "px",
		"default": 80
	},
	{
		"type": "range",
		"id": "section_padding_bottom_ipad",
		"label": "Section Padding Bottom",
		"min": 0,
		"max": 100,
		"step": 5,
		"unit": "px",
		"default": 80
	},
	{
		"type" : "paragraph",
		"content" : "Mobile"
	},
	{
		"type": "range",
		"id": "section_padding_top_xs",
		"label": "Section Padding Top",
		"min": 0,
		"max": 100,
		"step": 5,
		"unit": "px",
		"default": 60
	},
	{
		"type": "range",
		"id": "section_padding_bottom_xs",
		"label": "Section Padding Bottom",
		"min": 0,
		"max": 100,
		"step": 5,
		"unit": "px",
		"default": 60
	},
	{
		"type": "header",
		"content": "Section Top Border"
	},
	{
		"type" : "checkbox",
		"id" : "section_top_border_enable",
		"label" : "Show Top Border",
		"default" : false
	},
	{
		"type": "header",
		"content": "Show Row Reverse"
	},
	{
		"type" : "checkbox",
		"id" : "show_row_reverse",
		"label" : "Row Reverse",
		"default" : false
	},
	{
		"type" : "paragraph",
		"content" : "About Image"
	},
	{
		"type": "image_picker",
		"id": "home_about_image",
		"label": "Image",
		"info": "Recommended Size: 730x600px"
	},
	{
		"type" : "paragraph",
		"content" : "About Subtitle"
	},
	{
		"type": "text",
		"id": "about_subtitle",
		"label": "Subtitle",
		"default": "Healthcare is wealth"
	},
	{
		"type": "color",
		"id": "about_subtitle_color",
		"label": "Subtitle Color",
		"default": "#232323"
	},
	{
		"type" : "paragraph",
		"content" : "About Title"
	},
	{
		"type": "text",
		"id": "about_title_1",
		"label": "Title 1",
		"default": "Healthcare is a"
	},
	{
		"type": "text",
		"id": "about_title_2",
		"label": "Title 2",
		"default": "right, not a privilege"
	},
	{
		"type": "color",
		"id": "about_title_color",
		"label": "Title Color",
		"default": "#232323"
	},
	{
		"type" : "paragraph",
		"content" : "About desc"
	},
	{
		"type": "textarea",
		"id": "about_desc",
		"label": "About Description",
		"default": "There are many variations of passages of Lorem Ipsum available, but the majority have suffered alteration in some form, by injected humour, or randomised words which don't look even slightly believable"
	},
	{
		"type" : "paragraph",
		"content" : "About Button"
	},
	{
		"type": "text",
		"id": "about_btn_text",
		"label": "Button Text",
		"default": "Shop now"
	},
	{
		"type": "url",
		"id": "about_url",
		"label": "url"
	}
	],
	"presets":[
	{
		"name": "Custom Image & Text"
	}
	]
}
{% endschema %}
<style>
	.home-about-area{
		padding-top:{{ section.settings.section_padding_top }}px;
		padding-bottom:{{ section.settings.section_padding_bottom }}px;
		{% if section.settings.section_top_border_enable %}
		border-top: 1px solid #e2e2e2;
		{% endif %}
	}
	@media (max-width: 1199px){
		.home-about-area{
			padding-top:{{ section.settings.section_padding_top_lg }}px;
			padding-bottom:{{ section.settings.section_padding_bottom_lg }}px;
		}
	}
	@media (max-width: 767px){
		.home-about-area {
			padding-top:{{ section.settings.section_padding_top_xs }}px;
			padding-bottom:{{ section.settings.section_padding_bottom_xs }}px;
		}
	}
	.home-about-area .about-area {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: center;
		{% if settings.enable_rtl %}
		margin-right: -50px;
		{% else %}
		margin-left: -50px;
		{% endif %}
	}
	{% if section.settings.show_row_reverse %}
	.home-about-area .about-area.row-reverse {
		flex-direction: row-reverse;
	}
	{% endif %}
	.home-about-area .about-area .about-image {
		width: calc(50% - 50px);
		{% if settings.enable_rtl %}
		margin-right: 50px;
		{% else %}
		margin-left: 50px;
		{% endif %}
	}
	.home-about-area .about-area .about-content {
		width: calc(50% - 50px);
		{% if settings.enable_rtl %}
		margin-right: 50px;
		{% else %}
		margin-left: 50px;
		{% endif %}
	}
	.home-about-area .about-area .about-content span.subtitle {
		font-size: 20px;
		margin-bottom: 32px;
		font-weight: 500;
		line-height: 1;
	}
	.home-about-area .about-area .about-content h2.title {
		font-size: 36px;
		font-weight: 600;
		line-height: 1;
	}
	.home-about-area .about-area .about-content h2.title span {
		display: block;
		margin-top: 5px;
	}
	.home-about-area .about-area .about-content h2.title span:first-child {
		margin-top: 0px;
	}
	.home-about-area .about-area .about-content p {
		color: #999999;
		
		margin-top: 27px;
	}
	.home-about-area .about-area .about-content a {
		margin-top: 32px;
	}
	@media (max-width: 1199px) {
		.home-about-area .about-area .about-content span.subtitle {
			font-size: 17px;
			margin-bottom: 23px;
		}
		.home-about-area .about-area .about-content h2.title {
			font-size: 29px;
		}
		.home-about-area .about-area .about-content p {
			margin-top: 18px;
		}
		.home-about-area .about-area .about-content a {
			margin-top: 22px;
		}
	}
	@media (max-width: 991px) {
		.home-about-area .about-area {
			{% if settings.enable_rtl %}
			margin-right: 0px;
			{% else %}
			margin-left: 0px;
			{% endif %}
		}
		.home-about-area .about-area .about-image {
			width: calc(100% - 0px);
			display: flex;
    		justify-content: center;
			max-width: 100%;
    		display: block;
    		margin: 0 auto;
			{%- if settings.enable_rtl -%}
			margin-right: 0px;
			{%- else -%}‚
			margin-left: 0px;
			{%- endif -%}
		}
		.home-about-area .about-area .about-content {
			width: calc(100% - 0px);
			margin-top: 37px;
			{%- if settings.enable_rtl -%}
			margin-right: 0px;
			{%- else -%}
			margin-left: 0px;
			{%- endif -%}
		}
	}
	@media (max-width: 479px) {
		.home-about-area .about-area .about-content span.subtitle {
			font-size: 16px;
		}
		.home-about-area .about-area .about-content h2.title {
			font-size: 20px;
		}
	}
</style>