    }
    .cart-pro-err {
      grid-column: 1 / -1;
      grid-row: 3;
    }
  }

  /* Mesafeli Sozlesme Checkbox Alignment Fix */
  .mesafeli-sozlesme-app-wrapper {
    margin-top: 15px;
    margin-bottom: 15px;
    width: 100%;
  }
  /* Hedeflenen kapsayicilarin icindeki bloklari yan yana getir */
  .mesafeli-sozlesme-app-wrapper > div,
  .mesafeli-sozlesme-app-wrapper > p,
  .mesafeli-sozlesme-app-wrapper > label,
  .mesafeli-sozlesme-app-wrapper .checkbox-wrapper,
  .mesafeli-sozlesme-app-wrapper .terms-row {
    display: flex !important;
    align-items: flex-start !important;
    gap: 10px !important;
    margin-bottom: 12px !important;
    margin-left: 0 !important;
    padding-left: 0 !important;
    text-align: left !important;
    width: 100% !important;
  }
  .mesafeli-sozlesme-app-wrapper input[type="checkbox"] {
    margin-top: 3px !important;
    margin-right: 0 !important;
    margin-left: 0 !important;
    padding-left: 0 !important;
    width: 18px !important;
    height: 18px !important;
    flex-shrink: 0 !important;
    cursor: pointer !important;
    display: inline-block !important;
  }
  .mesafeli-sozlesme-app-wrapper label,
  .mesafeli-sozlesme-app-wrapper span {
    display: inline !important;
    line-height: 1.4 !important;
    font-size: 13.5px !important;
    color: #444 !important;
    margin: 0 !important;
  }
  .mesafeli-sozlesme-app-wrapper a {
    display: inline !important;
    text-decoration: underline !important;
    color: #1a1a2e !important;
    font-weight: 500 !important;
  }

  /* Sepet bos oldugunda mobildeki target'i gizle */
  ajax-items.is-empty ~ #mobile-terms-target,
  .cart-body.is-empty ~ #mobile-terms-target {
    display: none !important;
  }
</style>

<script>
  // Mesafeli Sozlesme App Proxy and Relocation Script
  document.addEventListener('DOMContentLoaded', function () {
    const cartBlocks = document.querySelector('.cart-blocks');
    const targetMobile = document.getElementById('mobile-terms-target');
    const mobileTrigger = document.getElementById('mobile-checkout-trigger');
    const desktopCheckoutBtn = document.getElementById('checkout');

    if (!cartBlocks || !targetMobile || !mobileTrigger || !desktopCheckoutBtn) return;

    let appTermsElement = null;

    function moveTerms() {
      if (!appTermsElement) return;
      
      const currentCartBlocks = document.querySelector('.cart-blocks');
      const currentDesktopCheckoutBtn = document.getElementById('checkout');
      const currentTargetMobile = document.getElementById('mobile-terms-target');
      
      if (window.innerWidth <= 767) {
        if (currentTargetMobile && appTermsElement.parentNode !== currentTargetMobile) {
          currentTargetMobile.appendChild(appTermsElement);
        }
      } else {
        if (currentCartBlocks && currentDesktopCheckoutBtn && appTermsElement.parentNode !== currentCartBlocks && appTermsElement.parentNode !== currentDesktopCheckoutBtn.parentNode) {
          currentCartBlocks.insertBefore(appTermsElement, currentDesktopCheckoutBtn.parentNode);
        }
      }
    }

    function checkAndSetAppElement(node) {
      if (node.nodeType === 1 && 
          !node.classList.contains('js-contents-subtotal') && 
          !node.classList.contains('checkout-btn') &&
          node.tagName !== 'SCRIPT' && 
          node.tagName !== 'STYLE') {
        
        if (!node.classList.contains('mesafeli-sozlesme-app-wrapper')) {
          node.classList.add('mesafeli-sozlesme-app-wrapper');
          
          // Yapisi bozuk html'i duzenle: Input ve Span'lari div icine al, &nbsp; ve <br>'leri sil.
          const inputs = node.querySelectorAll('input[type="checkbox"]');
          inputs.forEach(input => {
            const span = input.nextElementSibling;
            if (span && span.tagName === 'SPAN') {
              const wrapper = document.createElement('div');
              wrapper.className = 'terms-row';
              input.parentNode.insertBefore(wrapper, input);
              wrapper.appendChild(input);
              wrapper.appendChild(span);
            }
          });

          // Text node'lari (bosluk, &nbsp;) ve BR'leri temizle
          Array.from(node.childNodes).forEach(child => {
            if (child.nodeType === 3 || child.tagName === 'BR') {
              child.remove();
            }
          });
        }

        appTermsElement = node;
        moveTerms();
        return true;
      }
      return false;
    }

    const observer = new MutationObserver(function(mutations) {
      mutations.forEach(function(mutation) {
        mutation.addedNodes.forEach(function(node) {
          checkAndSetAppElement(node);
        });
      });
    });

    if (cartBlocks) {
      observer.observe(cartBlocks, { childList: true, subtree: false });
    }

    // Ajax güncellemelerine karşı 100% dirençli Interval
    setInterval(() => {
      const possibleNewNode = document.getElementById('ors_a8_order_div');
      if (possibleNewNode && possibleNewNode !== appTermsElement) {
        checkAndSetAppElement(possibleNewNode);
      }
      if (appTermsElement) {
        moveTerms();
      }
    }, 400);

    // Yeni yuklemelerde aninda tepki icin Observer'i guncelleme
    if (typeof user === 'function' && typeof SP_OBJECT !== 'undefined') {
      user(SP_OBJECT.ajxcartRefresh, function() {
        const newCartBlocks = document.querySelector('.cart-blocks');
        if (newCartBlocks) {
          observer.disconnect();
          observer.observe(newCartBlocks, { childList: true, subtree: false });
        }
        if (appTermsElement) moveTerms();
      });
    }

    if (cartBlocks) {
      Array.from(cartBlocks.children).forEach(child => {
        checkAndSetAppElement(child);
      });
    }

    window.addEventListener('resize', moveTerms);

    // Özel Ödeme Yönlendirmesi ve Validasyon (Bozulan app veya HTML5 engellerini aşar)
    document.addEventListener('click', function(e) {
      const mobileBtn = e.target.closest('#mobile-checkout-trigger');
      const desktopBtn = e.target.closest('#checkout');
      
      if (!mobileBtn && !desktopBtn) return;
      
      e.preventDefault();
      
      let allChecked = true;
      if (appTermsElement) {
        const checkboxes = appTermsElement.querySelectorAll('input[type="checkbox"]');
        if (checkboxes.length > 0) {
          checkboxes.forEach(cb => {
            if (!cb.checked) allChecked = false;
          });
        }
      }

      if (!allChecked && appTermsElement) {
        appTermsElement.scrollIntoView({ behavior: 'smooth', block: 'center' });
        
        const firstUnchecked = Array.from(appTermsElement.querySelectorAll('input[type="checkbox"]')).find(cb => !cb.checked);
        if (firstUnchecked && typeof firstUnchecked.reportValidity === 'function') {
          firstUnchecked.reportValidity();
        } else {
          alert('Lütfen Mesafeli Satış Sözleşmesi ve Ön Bilgilendirme Formunu onaylayın.');
        }
      } else {
        const form = document.getElementById('cart');
        if (form) {
          if (appTermsElement) {
             appTermsElement.querySelectorAll('input').forEach(i => i.removeAttribute('required'));
          }
          let hiddenInput = form.querySelector('input[name="checkout"]');
          if (!hiddenInput) {
            hiddenInput = document.createElement('input');
            hiddenInput.type = 'hidden';
            hiddenInput.name = 'checkout';
            hiddenInput.value = 'Checkout';
            form.appendChild(hiddenInput);
          }
          form.submit();
        }
      }
    });
  });
</script>
