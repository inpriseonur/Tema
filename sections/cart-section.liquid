{%- unless settings.cart_type == 'drawer' -%}
<script src="{{ 'cart.js' | asset_url }}" defer="defer"></script>
{%- endunless -%}
<section class="cart-page">
  <div class="container">
    <div class="row">
      <div class="col">
        <div class="grid-wrap">
          <div class="item-wrpper">
            <ajax-items class="cart-body{% if cart == empty %} is-empty{% endif %}">
                {% if settings.is_free_shipping_bar %}
                {% liquid assign promote_txt = settings.promote_free_shipping_txt | escape
                assign unlocked_txt = settings.unlocked_free_shipping_txt | escape
                assign threshold = settings.free_shipping_threshold | times: 100
                assign shipping_quotient = settings.free_shipping_threshold | times: 100 | divided_by: 100
                assign shipping_procent = cart.total_price | divided_by: shipping_quotient | at_most: 100
                assign value_left = threshold | minus: cart.total_price
                assign value_left_money = value_left | money %}
                <style>
                :root {
                  --shipping_procent: {{ shipping_procent }}%;
                }
                </style>
                <div class="shipping-bar" data-promote="{{ promote_txt }}" data-unlocked="{{ unlocked_txt }}" data-threshold="{{ threshold }}" data-quotient="{{ shipping_quotient }}" data-procent="{{ shipping_procent }}">
                  {% if value_left <= 0 %}
                  <p class="shipping-bar-success shipping-text">{{ unlocked_txt }}</p>
                  {% else %}
                  <p class="shipping-text">{{ promote_txt | replace: '[value]' , value_left_money }}</p>
                  {% endif %}
                  <div class="ship-probar"></div>
                </div>
                {% endif %}
                <div class="cart-empty-title">
                  <h6>
                    {{ 'sections.cart.empty' | t }}
                    {% if section.settings.shop_button != '' %}
                    <a href="{{ section.settings.shop_button_url }}">{{ section.settings.shop_button }}</a>
                    {%- endif -%}
                  </h6>
                </div>
                <div class="cart-body-item" id="cart-section" data-id="{{ section.id }}">
                  <form action="{{ routes.cart_url }}" method="post" id="cart">
                    <div class="js-contents">
                      {%- if cart != empty -%}
                        <table>
                          <thead>
                            <tr>
                              <th>{{ 'sections.cart.headings.product' | t }}</th>
                              <th>{{ 'sections.cart.headings.quantity' | t }}</th>
                              <th>{{ 'sections.cart.headings.total' | t }}</th>
                            </tr>
                          </thead>
                          <tbody>
                            {%- for item in cart.items -%}
                              <tr class="cart-item" id="cartpro-{{ item.index | plus: 1 }}">
                                <td class="item-media">
                                  <div class="cart-image">
                                  {% if item.image %}
                                  <a href="{{ item.url }}" class="img">
                                    <img src="{{ item.image | image_url: width: 300 }}" class="img-fluid lazyload item-img" alt="{{ item.image.alt | escape }}" loading="lazy" width="150" height="{{ 150 | divided_by: item.image.aspect_ratio | ceil }}">
                                  </a>
                                  {% endif %}
                                  <div class="item-info">
                                    <a href="{{ item.url }}" class="item-title">{{ item.product.title | escape }}</a>

                                    {%- if item.product.has_only_default_variant == false
                                    or item.properties.size != 0
                                    or item.selling_plan_allocation != null
                                    -%}
                                    <div class="item-option">
                                      {%- if item.product.has_only_default_variant == false -%}
                                          {{ item.options_with_values | map: "value" | join: " " }}
                                      {%- endif -%}
                                      {%- for property in item.properties -%}
                                        {%- assign property_first_char = property.first | slice: 0 -%}
                                        {%- if property.last != blank and property_first_char != '_' -%}
                                          <span class="swatch-item">
                                            <span class="heading">{{ property.first }}:</span>
                                            {%- if property.last contains '/uploads/' -%}
                                              <a href="{{ property.last }}" class="link" target="_blank">
                                                {{ property.last | split: '/' | last }}
                                              </a>
                                            {%- else -%}
                                              {{ property.last }}
                                            {%- endif -%}
                                          </span>
                                        {%- endif -%}
                                      {%- endfor -%}
                                    </div>
                                    {%- endif -%}
                                    <ul class="discounts list-unstyled" role="list" aria-label="{{ 'customer.order.discount' | t }}">
                                      {%- for discount in item.discounts -%}
                                        <li class="discounts__discount">
                                          <i class="fa fa-tag"></i>
                                          {{ discount.title }}
                                        </li>
                                      {%- endfor -%}
                                    </ul>
                                  </div>
                                  </div>
                                </td>
                                <td class="item-quantity">
                                  <div class="cart-item__quantity-wrapper">
                                    <div class="cart-qty-box">
                                    <qty-box class="quantity qty-box">
                                      <button class="qty-bt" name="minus" type="button">-</button>
                                      <input
                                      class="qty-box-input"
                                      data-quantity-variant-id="{{ item.variant.id }}"
                                      type="number"
                                      name="updates[]"
                                      value="{{ item.quantity }}"
                                      label="quantity"
                                      data-cart-quantity="{{ cart | item_count_for_variant: item.variant.id }}"
                                      min="{{ item.variant.quantity_rule.min }}"
                                      {% if item.variant.quantity_rule.max != null %}
                                        max="{{ item.variant.quantity_rule.max }}"
                                      {% endif %}
                                      step="{{ item.variant.quantity_rule.increment }}"
                                      aria-label="{{ 'products.product.quantity.input_label' | t: product: item.product.title | escape }}"
                                      id="Quantity-{{ item.index | plus: 1 }}"
                                      data-index="{{ item.index | plus: 1 }}"
                                      >
                                      <button class="qty-bt" name="plus" type="button">+</button>
                                    </qty-box>
                                    </div>
                                  </div>
                                  <div class="cart-pro-err" id="cart-pro-err-{{ item.index | plus: 1 }}" role="alert">
                                    <p class="cart-pro-err-text"></p>
                                    <svg aria-hidden="true" focusable="false" class="icon icon-error" viewBox="0 0 13 13">
                                      <circle cx="6.5" cy="6.50049" r="5.5" stroke="white" stroke-width="2"/>
                                      <circle cx="6.5" cy="6.5" r="5.5" fill="#EB001B" stroke="#EB001B" stroke-width="0.7"/>
                                      <path d="M5.87413 3.52832L5.97439 7.57216H7.02713L7.12739 3.52832H5.87413ZM6.50076 9.66091C6.88091 9.66091 7.18169 9.37267 7.18169 9.00504C7.18169 8.63742 6.88091 8.34917 6.50076 8.34917C6.12061 8.34917 5.81982 8.63742 5.81982 9.00504C5.81982 9.37267 6.12061 9.66091 6.50076 9.66091Z" fill="white"/>
                                      <path d="M5.87413 3.17832H5.51535L5.52424 3.537L5.6245 7.58083L5.63296 7.92216H5.97439H7.02713H7.36856L7.37702 7.58083L7.47728 3.537L7.48617 3.17832H7.12739H5.87413ZM6.50076 10.0109C7.06121 10.0109 7.5317 9.57872 7.5317 9.00504C7.5317 8.43137 7.06121 7.99918 6.50076 7.99918C5.94031 7.99918 5.46982 8.43137 5.46982 9.00504C5.46982 9.57872 5.94031 10.0109 6.50076 10.0109Z" fill="white" stroke="#EB001B" stroke-width="0.7">
                                    </svg>
                                  </div>
                                </td>
                                <td class="cart-item-totals">
                                  <div class="cart-item-totals-inner">
                                    <div class="cart-item-prices">
                                      <div class="item-unit-price-mobile">
                                        {%- if item.original_price != item.final_price -%}
                                        <span class="price-item-sale">
                                          {{- item.original_price | money -}}
                                        </span>
                                        <span class="price-item-regular">
                                          {{ item.final_price | money }}
                                        </span>
                                        {%- else -%}
                                        <span>{{ item.original_price | money }}</span>
                                        {%- if item.variant.compare_at_price > item.variant.price -%}
                                        <span class="old-price" id="ComparePrice-{{ forloop.index }}">{{ item.variant.compare_at_price | money }}</span>
                                        {%- endif -%}
                                        {%- endif -%}
                                      </div>
                                      <div class="item-price">
                                        <span class="price-item price-item-regular">
                                          {{ item.final_line_price | money }}
                                        </span>
                                      </div>
                                    </div>
                                    <delpro-btn id="Remove-{{ item.index | plus: 1 }}" data-index="{{ item.index | plus: 1 }}">
                                      <a class="remove-product" href="{{ item.url_to_remove }}" aria-label="{{ 'sections.cart.remove_title' | t: title: item.title }}">
                                        <i class="ti ti-trash"></i>
                                      </a>
                                    </delpro-btn>
                                  </div>
                                </td>
                              </tr>
                            {%- endfor -%}
                          </tbody>
                        </table>
                      {%- endif -%}
                    </div>
                  
                  <p class="visually-hidden" id="stcart-region-text" aria-live="polite" role="status" aria-hidden="true"></p>
                  <p class="visually-hidden" id="ajaxcart-lineitemstatus" aria-live="polite" aria-hidden="true" role="status">Loading...</p>
                  {%- if section.settings.cart_discount_enable -%}
                  <div class="discount-content">
                    <div class="discount-block">
                      <span class="gift-icon"><i class="ti ti-gift"></i></span>
                      <input type="text" id="input-discount" name="discount" placeholder="{{ section.settings.cart_discount_placeholder_text }}">
                      <span class="send-icon"><i class="ti ti-arrow-right"></i></span>
                    </div>
                    {% if section.settings.shop_button != '' %}
                    <a href="{{ section.settings.shop_button_url }}" class="btn-style1">{{ section.settings.shop_button }}</a>
                    {%- endif -%}
                  </div>
                  {%- endif -%}
                  {%- if settings.show_cart_note -%}
                  <st-note class="cart-note">
                    <h6>{{ 'sections.cart.note' | t }}</h6>
                    <textarea class="text-area" name="note" form="cart" id="Cart-note" placeholder="{{ 'sections.cart.note' | t }}" rows="5">{{ cart.note }}</textarea>
                  </st-note>
                  {%- endif -%}
                  </form>
                </div>
            </ajax-items>
            {%- if section.settings.kurumsal_fatura_enable and cart != empty -%}
            {%- render 'kurumsal-fatura-modal', kf_button_text: section.settings.kf_button_text, kf_saved_text: section.settings.kf_saved_text -%}
            {%- endif -%}
            {%- if cart != empty -%}
            <div class="cart-comp-section" id="cart-comp-section" style="display:none;">
              <h5 class="cart-comp-section__title">Sepetini tamamla</h5>
              <div class="cart-comp-grid" id="cart-comp-grid"></div>
            </div>
            <script>
            (function(){
              document.addEventListener('DOMContentLoaded', function(){
                var MAX = 2;
                var sec = document.getElementById('cart-comp-section');
                var grid = document.getElementById('cart-comp-grid');
                if (!sec || !grid) return;

                fetch('/cart.js').then(function(r){return r.json();}).then(function(cart){
                  if (!cart.items || !cart.items.length) return;
                  var cids = cart.items.map(function(i){return i.product_id;});
                  var fetches = cids.map(function(pid){
                    return fetch('/recommendations/products.json?product_id='+pid+'&limit=3&intent=complementary')
                      .then(function(r){return r.json();})
                      .then(function(d){return d.products||[];})
                      .catch(function(){return [];});
                  });
                  Promise.all(fetches).then(function(results){
                    var seen={}, comp=[];
                    for(var i=0;i<results.length;i++){
                      for(var j=0;j<results[i].length;j++){
                        var p=results[i][j];
                        if(cids.indexOf(p.id)!==-1) continue;
                        if(seen[p.id]) continue;
                        seen[p.id]=true; comp.push(p);
                        if(comp.length>=MAX) break;
                      }
                      if(comp.length>=MAX) break;
                    }
                    if(!comp.length) {
                      /* YENİ KURAL: Sepet doluysa trending asla gösterilmeyecek. */
                      return;
                    }
                    var h='';
                    for(var k=0;k<comp.length;k++) h+=bCard(comp[k]);
                    grid.innerHTML=h;
                    sec.style.display='';
                    /* Trending gizli kalıyor (CSS zaten display:none yapıyor) */
                    grid.querySelectorAll('.cart-comp-card__add').forEach(function(b){b.addEventListener('click',hAdd);});
                  });
                });

                function bCard(p){
                  var v=p.variants[0], img=p.featured_image?p.featured_image.replace(/(\.[^\.]+)$/,'_300x$1'):'';
                  var pr=fMoney(v.price), cmp='';
                  if(v.compare_at_price&&v.compare_at_price>v.price) cmp='<span class="old-price">'+fMoney(v.compare_at_price)+'</span>';
                  var btn=v.available
                    ?'<button type="button" class="cart-comp-card__add btn-style1" data-vid="'+v.id+'"><i class="fa fa-plus"></i> Ekle</button>'
                    :'<button type="button" class="cart-comp-card__add btn-style1" disabled>Tukendi</button>';
                  return '<div class="cart-comp-card"><a href="'+p.url+'" class="cart-comp-card__img"><img src="'+img+'" alt="" loading="lazy" width="120" height="120"></a>'
                    +'<div class="cart-comp-card__info"><a href="'+p.url+'" class="cart-comp-card__name">'+(p.title||'').substring(0,45)+'</a>'
                    +'<div class="cart-comp-card__price"><span class="new-price">'+pr+'</span>'+cmp+'</div></div>'+btn+'</div>';
                }
                function hAdd(){
                  var b=this, vid=b.dataset.vid; if(!vid) return;
                  b.disabled=true; b.innerHTML='<span class="spinner-border spinner-border-sm"></span>';
                  fetch('/cart/add.js',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({id:parseInt(vid),quantity:1})})
                    .then(function(){window.location.reload();})
                    .catch(function(){b.innerHTML='<i class="fa fa-plus"></i> Ekle'; b.disabled=false;});
                }
                function fMoney(c){
                  if(typeof Shopify!=='undefined'&&Shopify.formatMoney) return Shopify.formatMoney(c,window.money_format||'{{amount_with_comma_separator}}TL');
                  return (c/100).toLocaleString('tr-TR',{minimumFractionDigits:2})+'TL';
                }
                function showTrending(){
                  var np=document.querySelector('.new-product');
                  if(np) np.classList.add('trending-visible');
                  if(sec) sec.style.display='none';
                }

                /* AJAX ile sepet boşaltılırsa trending göster */
                /* Hem class değişikliği hem de DOM güncellenmesi izleniyor */
                var cartBody=document.querySelector('.cart-body');
                if(cartBody){
                  new MutationObserver(function(){
                    var isEmpty = cartBody.classList.contains('is-empty')
                      || cartBody.querySelectorAll('table tbody tr').length === 0;
                    if(isEmpty) showTrending();
                  }).observe(cartBody,{attributes:true,attributeFilter:['class'],childList:true,subtree:true});
                }

              });
            })();
            </script>
            {%- endif -%}
            
            <!-- App terms will be moved here on mobile -->
            <div id="mobile-terms-target" class="mobile-terms-wrapper d-md-none" style="margin-top: 20px; padding: 0 15px;"></div>
            
            {%- if cart == empty -%}
            <script>
            /* Sayfa zaten bos yuklendiyse trending goster */
            document.addEventListener('DOMContentLoaded', function(){
              var np = document.querySelector('.new-product');
              if(np) {
                np.classList.add('trending-visible');
                setTimeout(function(){
                  window.dispatchEvent(new Event('resize'));
                  if(window.jQuery) {
                    jQuery('.new-product-slider').trigger('refresh.owl.carousel');
                  }
                }, 100);
              }
            });
            </script>
            {%- endif -%}
          </div>
          <div class="total-wrpper cart-body-total{% if cart == empty %} is-empty{% endif %}" id="cart-section-total" data-id="{{ section.id }}">
            <div class="cart-footer">
              {%- if section.settings.shipping_calculator_enable -%}
              <div class="cart-actions">
                {%- if section.settings.shipping_calculator_heading != '' -%}
                <h6>{{ section.settings.shipping_calculator_heading }}</h6>
                {%- endif -%}
                {%- render 'cart-shipping-calculator' -%}
              </div>
              {%- endif -%}
              <div class="desktop-cart-blocks d-none d-md-block">
                <div class="cart-blocks">
                  <div class="js-contents-subtotal" {{ block.shopify_attributes }}>
                    <div class="totals">
                      <span class="total-title">{{ 'sections.cart.subtotal' | t }}</span>
                      <span>{{ cart.total_price | money_with_currency }}</span>
                    </div>
                    {%- if cart.cart_level_discount_applications.size > 0 -%}
                    <ul class="discounts list-unstyled" role="list" aria-label="{{ 'customer.order.discount' | t }}">
                      {%- for discount in cart.cart_level_discount_applications -%}
                        <li class="discounts__discount discounts__discount--position">
                          <span>{{ discount.title }}
                          (-{{ discount.total_allocated_amount | money }})</span>
                        </li>
                      {%- endfor -%}
                    </ul>
                    {%- endif -%}
                    <small class="tax-note caption-large rte">
                      {%- if cart.taxes_included and shop.shipping_policy.body != blank -%}
                        {{ 'sections.cart.taxes_included_and_shipping_policy_html' | t: link: shop.shipping_policy.url }}
                      {%- elsif cart.taxes_included -%}
                        {{ 'sections.cart.taxes_included_but_shipping_at_checkout' | t }}
                      {%- elsif shop.shipping_policy.body != blank -%}
                        {{ 'sections.cart.taxes_and_shipping_policy_at_checkout_html' | t: link: shop.shipping_policy.url }}
                      {%- else -%}
                        {{ 'sections.cart.taxes_and_shipping_at_checkout' | t }}
                      {%- endif -%}
                    </small>
                  </div>
                  <div class="checkout-btn" {{ block.shopify_attributes }}>
                    <button class="btn-style1 check-btn" type="submit" id="checkout" name="checkout" form="cart">
                      {{ 'sections.cart.checkout' | t }}
                    </button>
                  </div>
                  {%- if section.settings.cart_trust_enable -%}
                    {%- assign cart_trust_has_item = false -%}
                    {%- if section.settings.cart_trust_1_enable and section.settings.cart_trust_1_title != blank -%}
                      {%- assign cart_trust_has_item = true -%}
                    {%- endif -%}
                    {%- if section.settings.cart_trust_2_enable and section.settings.cart_trust_2_title != blank -%}
                      {%- assign cart_trust_has_item = true -%}
                    {%- endif -%}
                    {%- if section.settings.cart_trust_3_enable and section.settings.cart_trust_3_title != blank -%}
                      {%- assign cart_trust_has_item = true -%}
                    {%- endif -%}
                    {%- if cart_trust_has_item -%}
                      <div class="cart-checkout-trust" aria-label="Sepet güven bilgileri">
                        {%- for i in (1..3) -%}
                          {%- liquid
                            assign enabled_key = 'cart_trust_' | append: i | append: '_enable'
                            assign icon_key = 'cart_trust_' | append: i | append: '_icon'
                            assign title_key = 'cart_trust_' | append: i | append: '_title'
                            assign text_key = 'cart_trust_' | append: i | append: '_text'
                            assign item_enabled = section.settings[enabled_key]
                            assign item_icon = section.settings[icon_key]
                            assign item_title = section.settings[title_key]
                            assign item_text = section.settings[text_key]
                          -%}
                          {%- if item_enabled and item_title != blank -%}
                            <div class="cart-checkout-trust__item">
                              <span class="cart-checkout-trust__icon" aria-hidden="true">
                                {%- case item_icon -%}
                                  {%- when 'package' -%}
                                    <svg viewBox="0 0 24 24"><path d="M21 8l-9-5-9 5 9 5 9-5z"></path><path d="M3 8v8l9 5 9-5V8"></path><path d="M12 13v8"></path></svg>
                                  {%- when 'shield' -%}
                                    <svg viewBox="0 0 24 24"><path d="M12 3l7 3v5c0 5-3 8-7 10-4-2-7-5-7-10V6z"></path><path d="M9 12l2 2 4-4"></path></svg>
                                  {%- when 'refresh' -%}
                                    <svg viewBox="0 0 24 24"><path d="M21 12a9 9 0 0 1-15.3 6.4"></path><path d="M3 12A9 9 0 0 1 18.3 5.6"></path><path d="M21 5v6h-6"></path><path d="M3 19v-6h6"></path></svg>
                                  {%- else -%}
                                    <svg viewBox="0 0 24 24"><path d="M3 7h11v10H3z"></path><path d="M14 10h4l3 3v4h-7z"></path><circle cx="7" cy="17" r="2"></circle><circle cx="18" cy="17" r="2"></circle></svg>
                                {%- endcase -%}
                              </span>
                              <span class="cart-checkout-trust__copy">
                                <strong>{{ item_title }}</strong>
                                {%- if item_text != blank -%}
                                  <span class="cart-checkout-trust__text">{{ item_text }}</span>
                                {%- endif -%}
                              </span>
                            </div>
                          {%- endif -%}
                        {%- endfor -%}
                      </div>
                    {%- endif -%}
                  {%- endif -%}
                </div>
              </div>

              {%- if section.settings.delivery_enable -%}
              <div class="cart-delivery-info d-none d-md-flex">
                <div class="cart-delivery-info__icon">
                  <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg>
                </div>
                <div class="cart-delivery-info__content">
                  <strong class="cart-delivery-info__title">{{ section.settings.delivery_title }}</strong>
                  <p class="cart-delivery-info__text">{{ section.settings.delivery_description }}</p>
                </div>
              </div>
              {%- endif -%}
            </div>
          </div>
        </div>
      </div>
      {%- if cart != empty -%}
      <div class="col-12 mobile-sticky-cart sticky d-md-none">
        {% liquid 
          assign ist_threshold = settings.istanbul_free_shipping_threshold | times: 100 
          assign ist_value_left = ist_threshold | minus: cart.total_price 
          assign ist_procent = cart.total_price | times: 100 | divided_by: ist_threshold | at_most: 100
          assign ist_value_left_money = ist_value_left | money
          assign ist_promote_txt = settings.istanbul_promote_free_shipping_txt | default: 'İstanbul ücretsiz özel teslimata <b>[value]</b> kaldı'
          assign ist_unlocked_txt = settings.istanbul_unlocked_free_shipping_txt | default: 'İstanbul içi <b>Ücretsiz Özel Teslimat</b> kazandınız!'
        %}
        <div class="ship-bar-bg"><div class="ship-bar-fill" style="width:{{ ist_procent }}%"></div></div>
        {% if ist_value_left <= 0 %}
          <p class="ship-text">{{ ist_unlocked_txt }}</p>
        {% else %}
          <p class="ship-text">{{ ist_promote_txt | replace: '[value]', ist_value_left_money }}</p>
        {% endif %}
        <div class="total-row js-contents-subtotal">
          <span class="total-label">Ara toplam</span>
          <span class="total-price">{{ cart.total_price | money }}</span>
        </div>
        <button id="mobile-checkout-trigger" class="checkout-btn-mobile" type="button">Ödemeye Geç →</button>
        <div class="trust-badges">
          {%- if settings.desktop_cta_badge_1_text != blank -%}
          <span class="trust-badge">
            {{ settings.desktop_cta_badge_1_icon }}
            {{ settings.desktop_cta_badge_1_text }}
          </span>
          {%- endif -%}
          {%- if settings.desktop_cta_badge_1_text != blank and settings.desktop_cta_badge_2_text != blank -%}
          <span class="trust-dot"></span>
          {%- endif -%}
          {%- if settings.desktop_cta_badge_2_text != blank -%}
          <span class="trust-badge">
            {{ settings.desktop_cta_badge_2_icon }}
            {{ settings.desktop_cta_badge_2_text }}
          </span>
          {%- endif -%}
          {%- if settings.desktop_cta_badge_2_text != blank and settings.desktop_cta_badge_3_text != blank -%}
          <span class="trust-dot"></span>
          {%- endif -%}
          {%- if settings.desktop_cta_badge_3_text != blank -%}
          <span class="trust-badge">
            {{ settings.desktop_cta_badge_3_icon }}
            {{ settings.desktop_cta_badge_3_text }}
          </span>
          {%- endif -%}
        </div>
      </div>
      {%- endif -%}
    </div>
  </div>
</section>
