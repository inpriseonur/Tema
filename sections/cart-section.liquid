<script>
  /* Mobilde footer'ı sticky bar'ın hemen altına yapıştır */
  if (window.innerWidth <= 767) {
    document.body.style.minHeight = 'auto';
    document.body.style.display = 'block';
    var mainEl = document.querySelector('main[role="main"]');
    if (mainEl) mainEl.style.flex = 'none';
  }
</script>
<script>
  document.addEventListener('DOMContentLoaded', function () {
    ShippingBar = (function() {
      var bar = document.querySelector('.shipping-bar');
      if(bar){
        var promote_txt = bar.dataset.promote;
        var unlocked_txt = bar.dataset.unlocked;
        var threshold = bar.dataset.threshold;
        var shipping_quotient = bar.dataset.quotient;
        var shipping_procent = bar.dataset.procent;
      }
        if(bar)
        {
          $.getJSON('/cart.js').then(
            function(cart) {
              var shipping_quotient = threshold * 100 / 100;
              var shipping_procent = cart.total_price / shipping_quotient;
              var value_left = threshold - cart.total_price;
              var value_left_money = Shopify.formatMoney(value_left,Shopify.moneyFormat);  
              ///alert(value_left_money);
              if(value_left >= 0){
                bar.innerHTML =  '<div class="ship-probar">' + '</div>';
              }
              if(value_left <= 0){
                bar.innerHTML =  '<p class="shipping-bar-success shipping-text">' + unlocked_txt + '</p>';
              }
              else{
                bar.innerHTML = '<p class="shipping-text">' + promote_txt.replace('[value]',value_left_money) + '</p>';
              }
            }
            );      
        }
        $(document).on("click", ".qty-bt,.remove-product", function() {
          setTimeout(function() {
              fetch('/cart?view=ajax&_=' + new Date().getTime())
              .then(response => {
                if (response.ok) {
                  return Promise.resolve(response);
                }
                else {
                  return Promise.reject(new Error('Failed to load')); 
                }
              })
              .then(response => response.text()) 
              .then(data => {
                
                const text = data;
                const parser = new DOMParser();
                const htmlDocument = parser.parseFromString(text, 'text/html');
                const cartHtml = htmlDocument.documentElement.querySelector('.cart-body').innerHTML;
                ///console.log(cartHtml);
                document.querySelector('.cart-body').innerHTML = cartHtml;
                
                const cartTotalHtml = htmlDocument.documentElement.querySelector('.cart-body-total').innerHTML;
                if (cartTotalHtml && document.querySelector('.cart-body-total')) {
                  document.querySelector('.cart-body-total').innerHTML = cartTotalHtml;
                }
                
                const isCartEmpty = htmlDocument.documentElement.querySelector('.cart-body') && htmlDocument.documentElement.querySelector('.cart-body').classList.contains('is-empty');
                
                var kfWrapper = document.getElementById('kurumsal-fatura-area');
                var mobileSticky = document.querySelector('.mobile-sticky-cart');
                
                if (isCartEmpty) {
                  if (kfWrapper) kfWrapper.style.display = 'none';
                  if (mobileSticky) mobileSticky.style.display = 'none';
                } else {
                  if (kfWrapper) kfWrapper.style.display = '';
                  if (mobileSticky) mobileSticky.style.display = '';
                  
                  const mobileStickyCartHtml = htmlDocument.documentElement.querySelector('.mobile-sticky-cart') ? htmlDocument.documentElement.querySelector('.mobile-sticky-cart').innerHTML : null;
                  if (mobileStickyCartHtml && mobileSticky) {
                    mobileSticky.innerHTML = mobileStickyCartHtml;
                  }
                  
                  const desktopShippingHtml = htmlDocument.documentElement.querySelector('.kf-ist-shipping-desktop') ? htmlDocument.documentElement.querySelector('.kf-ist-shipping-desktop').innerHTML : null;
                  if (desktopShippingHtml && document.querySelector('.kf-ist-shipping-desktop')) {
                    document.querySelector('.kf-ist-shipping-desktop').innerHTML = desktopShippingHtml;
                  }
                }
                
                /* Sepet bosaldiysa trending goster ve slider'i guncelle */
                fetch('/cart.js').then(r=>r.json()).then(cart => {
                  if(cart.item_count === 0) {
                    var np = document.querySelector('.new-product');
                    if(np) {
                      np.classList.add('trending-visible');
                      setTimeout(function(){
                        window.dispatchEvent(new Event('resize'));
                        if(window.jQuery) {
                          jQuery('.new-product-slider').trigger('refresh.owl.carousel');
                        }
                      }, 100);
                    }
                  }
                });
              })
              .catch(function(error) {
                console.log('Error: ' + error.message);
              });
            }, 1000); 
        });
    }) ();
  });
</script>
