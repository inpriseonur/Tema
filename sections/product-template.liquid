                        {%- assign mcd_today_ts = mcd_today | date: '%s' | plus: 0 -%}
                        {%- assign mcd_end = inner_block.settings.countdown_end_date | date: '%s' | plus: 0 -%}
                        {%- assign mcd_diff = mcd_end | minus: mcd_today_ts -%}
                        {%- assign mcd_days = mcd_diff | divided_by: 86400 -%}
