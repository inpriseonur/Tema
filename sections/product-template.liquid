{%- assign current_variant = product.selected_or_first_available_variant -%}
{%- assign explicitly_selected_variant = product.selected_variant -%}
{%- liquid
  assign packaging_video_index = blank
  assign packaging_video_media_id = blank
  assign mobile_gallery_aspect_ratio = blank
  assign desktop_gallery_ratio_percent = 100

  if current_variant.featured_media.media_type == 'image'
    assign mobile_gallery_aspect_ratio = current_variant.featured_media.preview_image.aspect_ratio
  endif

  if mobile_gallery_aspect_ratio == blank
    for media in product.media
      if media.media_type == 'image'
        assign mobile_gallery_aspect_ratio = media.preview_image.aspect_ratio
        break
      endif
    endfor
  endif

  for media in product.media
    assign media_alt_downcase = media.alt | downcase
    if media.media_type == 'video' or media.media_type == 'external_video'
      if media_alt_downcase contains 'paketleme-video'
        assign packaging_video_index = forloop.index0
        assign packaging_video_media_id = media.id
        break
      endif
    endif
  endfor

  if mobile_gallery_aspect_ratio == blank or mobile_gallery_aspect_ratio == 0
    assign mobile_gallery_aspect_ratio = 1
  endif
  assign mobile_gallery_ratio_percent = 1.0 | divided_by: mobile_gallery_aspect_ratio | times: 100

  if section.settings.image_ratio == 'portrait'
    assign desktop_gallery_ratio_percent = 125
  elsif section.settings.image_ratio == 'adapt'
    assign desktop_gallery_ratio_percent = mobile_gallery_ratio_percent
  endif
-%}
<section class="main-content-wrap product-details-page product-main-template{% if product.tags contains 'mobil-kompakt-gorsel' %} mobile-compact-media{% endif %}" id="MainProduct-{{ section.id }}" data-section="{{ section.id }}" style="--mobile-gallery-ratio-percent: {{ mobile_gallery_ratio_percent }}%; --desktop-gallery-ratio-percent: {{ desktop_gallery_ratio_percent }}%;">
  <div class="product-details">
    <div class="container">
      <div class="grid-wrap {% if section.settings.service_enable or section.settings.campaign_popup_enable %} service-wrap{% endif %} ">
        <div class="grid-wrapper pro-wrapper">
          <div class="detail-wrap">
            <div class="product_details">
              <div class="product_detail_img">
                <div class="product_img_top">
                  <div class="custom-badge-overlay">
                    {%- for block in section.blocks -%}
                      {%- if block.type == 'custom_badge' -%}
                        {%- if product.tags contains block.settings.badge_tag -%}
                          <div class="custom-badge-item position-{{ block.settings.badge_position }}" style="width: {{ block.settings.badge_width }}px;">
                            {%- if block.settings.badge_image != blank -%}
                              {{ block.settings.badge_image | image_url: width: 400 | image_tag: loading: 'lazy', alt: block.settings.badge_tag }}
                            {%- endif -%}
                          </div>
                        {%- endif -%}
                      {%- endif -%}
                    {%- endfor -%}
                  </div>
                  <div class="slider-big swiper slider-big-{{ product.id }}" id="slider-big-{{ product.id }}" {% if settings.enable_rtl %}dir="rtl"{% endif %} data-slides-per-view="1">
                    <div class="swiper-wrapper">
                      {%- for media in product.media -%}
                      {% assign i = forloop.index %}
                      <div class="swiper-slide" data-layout="thumb-slider" data-image="{{ media.src | image_url }}" data-image-id="{{ media.id }}" data-index="{{ i }}">
                        {% render 'media',
                          media: media,
                          section: section,
                          priority: forloop.first,
                          selected_variant_media_id: current_variant.featured_media.id
                        %}
                      </div>
                      {%- endfor -%}
                    </div>
                    <button type="button" class="big-button button-next" aria-label="Sonraki görsel"><i class="ti ti-arrow-right"></i></button>
                    <button type="button" class="big-button button-prev" aria-label="Önceki görsel"><i class="ti ti-arrow-left"></i></button>
                    {%- if product.media.size > 1 -%}
                      <div class="mobile-media-counter" data-mobile-media-counter aria-live="polite">
                        <span data-mobile-media-current>1</span>
                        <span aria-hidden="true">/</span>
                        <span>{{ product.media.size }}</span>
                      </div>
                    {%- endif -%}
                  </div>
                </div>
                <div class="pro-slider">
                  <button type="button" class="thumb-button thumb-button-prev" aria-label="Önceki görsel">
                    <i class="ti ti-angle-up"></i>
                  </button>
                  <div class="slider-small swiper slider-small-{{ product.id }}" id="slider-small-{{ product.id }}" {% if settings.enable_rtl %}dir="rtl"{% endif %} data-slides-per-view="4">
                    <div class="swiper-wrapper">
                      {% for media in product.media %}
                      {% assign i = forloop.index %}
                      {%- liquid
                        assign ratio = 1
                        if media.preview_image and section.settings.image_ratio == 'portrait'
                          assign ratio = 0.8
                        elsif media.preview_image and section.settings.image_ratio == 'adapt'
                          assign ratio = section.img_url.aspect_ratio
                        endif
                        if ratio == 0 or ratio == null
                          assign ratio = 1
                        endif
                      -%}
                      <div class="swiper-slide" data-layout="thumb-slider" data-image="{{ media.src | image_url }}" data-image-id="{{ media.id }}" data-index="{{ i }}">
                        <span class="product-thumb ratio" style="--ratio-percent: {{ 1 | divided_by: ratio | times: 100 }}%;">
                          <img
                            srcset="
                              {%- if media.preview_image.width >= 165 -%}{{ media.preview_image | image_url: width: 165 }} 165w,{%- endif -%}
                              {%- if media.preview_image.width >= 360 -%}{{ media.preview_image | image_url: width: 360 }} 360w,{%- endif -%}
                            "
                            src="{{ media.preview_image | image_url: width: 360 }}"
                            data-src="{{ media.preview_image | image_url: width: 360 }}"
                            alt="{{ media.preview_image.alt | escape }}"
                            class="img-fluid lazyload img1"
                            width="{{ media.preview_image.width }}"
                            height="{{ media.preview_image.width | divided_by: media.preview_image.aspect_ratio }}"
                            decoding="async"
                            loading="lazy"
                          >
                          {%- if media.media_type == 'video' or media.media_type == 'external_video' -%}
                          <span class="icon-play"><i class="fa fa-play"></i></span>
                          {%- endif -%}
                          {%- if media.media_type == 'model' -%}
                          <span class="icon-modal"><i class="fa fa-cube"></i></span>
                          {%- endif -%}
                        </span>
                      </div>
                      {% endfor %}
                    </div>
                  </div>
                  <button type="button" class="thumb-button thumb-button-next" aria-label="Sonraki görsel">
                    <i class="ti ti-angle-down"></i>
                  </button>
                </div>
              </div>
            </div>
            <div class="product_details detail-info">
              <div id="ProductInfo-{{ section.id }}" data-section="{{ section.id }}" data-url="{{ product.url }}" class="product__info-container">
                {%- assign product_form_id = 'product-form-' | append: section.id -%}
                <div class="product_details_info">
                  {%- for block in section.blocks -%}
                  {%- case block.type -%}
                  {%- when '@app' -%}
                  <div class="product-app-block" {{ block.shopify_attributes }}>
                    {% render block %}
                  </div>
                  {%- when 'text' -%}
                  {{- block.settings.text -}}
                  {%- when 'title_wrap' -%}
                  <div class="product-title" {{ block.shopify_attributes }}>
                    <h1 data-product-variant-title>
                      {{- product.title -}}
                      {%- if explicitly_selected_variant and product.has_only_default_variant == false -%}
                        {{- ' ' -}}{{- explicitly_selected_variant.options | join: ' ' -}}
                      {%- endif -%}
                    </h1>
                  </div>
                  {%- if settings.show_rating -%}
                    <div class="product-grid-rating product-social-proof">
                      {% if product.metafields.judgeme.badge %}
                      <div class='jdgm-widget jdgm-preview-badge'>
                        {{ product.metafields.judgeme.badge }}
                      </div>
                      {% else %}
                      <div class="jdgm-prev-badge jdgm--js" data-average-rating="0.00" data-number-of-reviews="0">
                        <span class="jdgm-prev-badge__stars" data-score="0.00"><span class="jdgm-star jdgm--off"></span><span class="jdgm-star jdgm--off"></span><span class="jdgm-star jdgm--off"></span><span class="jdgm-star jdgm--off"></span><span class="jdgm-star jdgm--off"></span></span>
                        <span class="jdgm-prev-badge__text">No reviews</span>
                      </div>
                      {% endif %}
                      {%- assign social_satis_adedi = product.metafields.custom.satis_adedi | default: 0 | plus: 0 -%}
                      {%- if social_satis_adedi > 0 -%}
                        <span class="product-social-proof__separator">·</span>
                        <span class="product-social-proof__sales">Bu ay {{ social_satis_adedi }} adet satın alındı</span>
                      {%- endif -%}
                    </div>
                    {%- endif -%}
                  {%- when 'sales_count' -%}
                  {%- assign satis_adedi = product.metafields.custom.satis_adedi | default: 0 | plus: 0 -%}
                  {%- if satis_adedi >= block.settings.min_count -%}
                    <div class="product-sales-badge product-social-proof-sales" {{ block.shopify_attributes }} style="color: {{ block.settings.text_color }};">
                      {%- if block.settings.custom_icon != blank -%}
                        <span class="sales-icon">{{ block.settings.custom_icon }}</span>
                      {%- endif -%}
                      <span class="sales-text">
                        {{ block.settings.text_template | replace: '[count]', satis_adedi }}
                      </span>
                    </div>
                  {%- endif -%}
                  {%- when 'trust_badge' -%}
                  <style>
                    .product-trust-badge {
                      display: flex;
                      align-items: center;
                      gap: 12px;
                      padding: 12px 16px;
                      border-radius: 8px;
                      margin-bottom: 15px;
                      font-size: 13px;
                      font-weight: 500;
                      font-family: var(--font-body-family), sans-serif;
                    }
                    .product-trust-badge .trust-icon {
                      display: flex;
                      align-items: center;
                      justify-content: center;
                      width: 26px;
                      height: 26px;
                      flex-shrink: 0;
                    }
                    .product-trust-badge .trust-icon svg {
                      width: 20px;
                      height: 20px;
                    }
                    .product-trust-badge .trust-text {
                      display: flex;
                      flex-direction: column;
                      justify-content: center;
                    }
                    .product-trust-badge .trust-text p {
                      margin: 0;
                      display: block;
                      line-height: 1.2;
                    }
                    .product-trust-badge .trust-text a {
                      color: {{ block.settings.link_color | default: block.settings.text_color }};
                      text-decoration: underline;
                      font-weight: 600;
                      vertical-align: baseline;
                    }
                    .product-trust-badge .trust-text a:hover {
                      opacity: 0.8;
                    }
                  </style>
                  <div class="product-trust-badge" {{ block.shopify_attributes }} style="background-color: {{ block.settings.bg_color }}; color: {{ block.settings.text_color }}; border: 1px solid {{ block.settings.border_color }}; border-left: 4px solid #3B6D11;">
                    {%- if block.settings.icon != blank -%}
                      <span class="trust-icon">{{ block.settings.icon }}</span>
                    {%- endif -%}
                    <div class="trust-text">{{ block.settings.text | replace: '<a ', '<a style="vertical-align: baseline;" target="_blank" ' }}</div>
                  </div>
                  {%- when 'cod_message' -%}
                  <style>
                    .product-cod-message {
                      display: flex;
                      align-items: center;
                      justify-content: space-between;
                      background-color: {{ block.settings.bg_color }};
                      border: 1px solid {{ block.settings.border_color }};
                      border-left: 4px solid {{ block.settings.border_left_color }};
                      padding: 12px 16px;
                      border-radius: 8px;
                      margin-bottom: 15px;
                      font-family: var(--font-body-family), sans-serif;
                    }
                    .product-cod-message .cod-left {
                      display: flex;
                      align-items: center;
                      gap: 12px;
                    }
                    .product-cod-message .cod-icon {
                      display: flex;
                      align-items: center;
                      justify-content: center;
                      width: 26px;
                      height: 26px;
                      border-radius: 50%;
                      background-color: {{ block.settings.icon_bg_color }};
                      flex-shrink: 0;
                    }
                    .product-cod-message .cod-icon svg {
                      width: 14px;
                      height: 14px;
                      fill: none;
                      stroke: {{ block.settings.icon_stroke_color }};
                      stroke-width: 1.5;
                      stroke-linecap: round;
                      stroke-linejoin: round;
                    }
                    .product-cod-message .cod-text-wrap {
                      display: flex;
                      flex-direction: column;
                      justify-content: center;
                    }
                    .product-cod-message .cod-title {
                      font-size: 14px;
                      font-weight: 600;
                      color: {{ block.settings.title_color }};
                      line-height: 1.2;
                      margin-bottom: 2px;
                      white-space: nowrap;
                    }
                    .product-cod-message .cod-subtitle {
                      font-size: 12px;
                      font-weight: 500;
                      color: {{ block.settings.subtitle_color }};
                      line-height: 1.2;
                    }
                    .product-cod-message .cod-right .cod-badge {
                      background-color: transparent;
                      color: {{ block.settings.badge_bg_color }};
                      border: 1px solid {{ block.settings.badge_bg_color }};
                      font-size: 10px;
                      font-weight: 500;
                      padding: 2px 8px;
                      border-radius: 4px;
                      letter-spacing: 0.5px;
                      white-space: nowrap;
                    }
                  </style>
                  <div class="product-cod-message" {{ block.shopify_attributes }}>
                    <div class="cod-left">
                      <div class="cod-icon">
                        <svg viewBox="0 0 24 24">
                          <rect x="3" y="8" width="18" height="12" rx="2" ry="2"></rect>
                          <path d="M12 8v12"></path>
                          <path d="M8 14h8"></path>
                          <path d="M16 8V6a2 2 0 0 0-2-2H10a2 2 0 0 0-2 2v2"></path>
                        </svg>
                      </div>
                      <div class="cod-text-wrap">
                        <span class="cod-title">{{ block.settings.title }}</span>
                        <span class="cod-subtitle">{{ block.settings.sub_message }}</span>
                      </div>
                    </div>

                  </div>
                  {%- when 'purchase_trust_messages' -%}
                  {%- liquid
                    assign has_purchase_trust_message = false
                    for message_index in (1..3)
                      assign enabled_key = 'message_' | append: message_index | append: '_enabled'
                      assign title_key = 'message_' | append: message_index | append: '_title'
                      if block.settings[enabled_key] and block.settings[title_key] != blank
                        assign has_purchase_trust_message = true
                      endif
                    endfor
                  -%}
                  {%- if has_purchase_trust_message -%}
                    <div
                      class="purchase-trust-messages purchase-trust-messages--{{ block.settings.layout_style }}{% unless block.settings.show_desktop %} purchase-trust-messages--hide-desktop{% endunless %}{% unless block.settings.show_mobile %} purchase-trust-messages--hide-mobile{% endunless %}{% unless block.settings.mobile_show_subtitles %} purchase-trust-messages--mobile-hide-subtitles{% endunless %}"
                      {{ block.shopify_attributes }}
                    >
                      {%- for message_index in (1..3) -%}
                        {%- liquid
                          assign enabled_key = 'message_' | append: message_index | append: '_enabled'
                          assign title_key = 'message_' | append: message_index | append: '_title'
                          assign subtitle_key = 'message_' | append: message_index | append: '_subtitle'
                           assign icon_key = 'message_' | append: message_index | append: '_icon'
                           assign tone_key = 'message_' | append: message_index | append: '_tone'
                           assign video_enabled_key = 'message_' | append: message_index | append: '_packaging_video_enabled'
                           assign video_title_key = 'message_' | append: message_index | append: '_packaging_video_title'
                           assign video_subtitle_key = 'message_' | append: message_index | append: '_packaging_video_subtitle'
                           assign message_enabled = block.settings[enabled_key]
                           assign message_title = block.settings[title_key]
                           assign message_subtitle = block.settings[subtitle_key]
                           assign message_icon = block.settings[icon_key]
                           assign message_tone = block.settings[tone_key]
                           assign message_is_packaging_video = false

                           if message_enabled and block.settings[video_enabled_key] and packaging_video_index != blank
                             assign message_is_packaging_video = true
                             if block.settings[video_title_key] != blank
                               assign message_title = block.settings[video_title_key]
                             endif
                             if block.settings[video_subtitle_key] != blank
                               assign message_subtitle = block.settings[video_subtitle_key]
                             endif
                           endif
                         -%}
                         {%- if message_enabled and message_title != blank -%}
                           {%- if message_is_packaging_video -%}
                             <button
                               type="button"
                               class="purchase-trust-message purchase-trust-message--{{ message_tone }} purchase-trust-message--interactive"
                               data-packaging-video-cta
                               data-packaging-video-index="{{ packaging_video_index }}"
                             >
                           {%- else -%}
                             <div class="purchase-trust-message purchase-trust-message--{{ message_tone }}">
                           {%- endif -%}
                             <span class="purchase-trust-message__icon" aria-hidden="true">
                               {%- if message_is_packaging_video -%}
                                 <svg class="purchase-trust-message__play-icon" viewBox="0 0 24 24"><path d="M9 7l8 5-8 5z"></path></svg>
                               {%- else -%}
                               {%- case message_icon -%}
                                 {%- when 'shipping' -%}
                                   <svg viewBox="0 0 24 24"><path d="M3 7h11v10H3z"></path><path d="M14 10h4l3 3v4h-7z"></path><circle cx="7" cy="17" r="2"></circle><circle cx="18" cy="17" r="2"></circle></svg>
                                {%- when 'clock' -%}
                                  <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"></circle><path d="M12 7v5l3 2"></path></svg>
                                {%- when 'payment' -%}
                                  <svg viewBox="0 0 24 24"><rect x="3" y="6" width="18" height="12" rx="2"></rect><path d="M3 10h18"></path><path d="M7 15h4"></path></svg>
                                {%- when 'secure' -%}
                                  <svg viewBox="0 0 24 24"><path d="M12 3l7 3v5c0 5-3 8-7 10-4-2-7-5-7-10V6z"></path><path d="M9 12l2 2 4-4"></path></svg>
                                {%- when 'support' -%}
                                  <svg viewBox="0 0 24 24"><path d="M4 12a8 8 0 0 1 16 0"></path><path d="M4 12v4a2 2 0 0 0 2 2h2v-6H4z"></path><path d="M20 12v4a2 2 0 0 1-2 2h-2v-6h4z"></path><path d="M9 20h3"></path></svg>
                                 {%- else -%}
                                   <svg viewBox="0 0 24 24"><path d="M20 6L9 17l-5-5"></path></svg>
                               {%- endcase -%}
                               {%- endif -%}
                             </span>
                             <span class="purchase-trust-message__text">
                               <span class="purchase-trust-message__title">{{ message_title }}</span>
                              {%- if message_subtitle != blank -%}
                                 <span class="purchase-trust-message__subtitle">{{ message_subtitle }}</span>
                               {%- endif -%}
                             </span>
                             {%- if message_is_packaging_video -%}
                               <span class="purchase-trust-message__action" aria-hidden="true">
                                 <span>İzle</span>
                                 <svg viewBox="0 0 24 24"><path d="M9 5l7 7-7 7"></path></svg>
                               </span>
                             {%- endif -%}
                           {%- if message_is_packaging_video -%}
                             </button>
                           {%- else -%}
                             </div>
                           {%- endif -%}
                         {%- endif -%}
                       {%- endfor -%}
                     </div>
                   {%- endif -%}
                   {%- when 'inventory' -%}
                  <div class="product-inventory{% if product.selected_or_first_available_variant.inventory_management != 'shopify' %} hidden{% endif %}" {{ block.shopify_attributes }} id="Inventory-{{ section.id }}" role="status">
                    <h6>{{ block.settings.availability_title }}</h6>
                    {%- if product.selected_or_first_available_variant.inventory_management == 'shopify' -%}
                      {%- if product.selected_or_first_available_variant.inventory_quantity > 0 -%}
                        {%- if product.selected_or_first_available_variant.inventory_quantity <= block.settings.inventory_threshold -%}
                          <svg width="15" height="15" aria-hidden="true">
                            <circle cx="7.5" cy="7.5" r="7.5" fill="rgb(238,148,65, 0.3)"/>
                            <circle cx="7.5" cy="7.5" r="5" stroke="rgb(255, 255, 255)" stroke-width="1" fill="rgb(238,148,65)"/>
                          </svg>
                          {%- if block.settings.show_inventory_quantity -%}
                            <span>{{- 'products.product.inventory_low_stock_show_count' | t: quantity: product.selected_or_first_available_variant.inventory_quantity -}}</span>
                          {%- else -%}
                            <span>{{- 'products.product.inventory_low_stock' | t -}}</span>
                          {%- endif -%}
                        {%- else -%}
                          <svg width="15" height="15" aria-hidden="true">
                            <circle cx="7.5" cy="7.5" r="7.5" fill="rgb(62,214,96, 0.3)"/>
                            <circle cx="7.5" cy="7.5" r="5" stroke="rgb(255, 255, 255)" stroke-width="1" fill="rgb(62,214,96)"/>
                          </svg>
                          {%- if block.settings.show_inventory_quantity -%}
                           <span>{{- 'products.product.inventory_in_stock_show_count' | t: quantity: product.selected_or_first_available_variant.inventory_quantity -}}</span>
                          {%- else -%}
                            <span>{{- 'products.product.inventory_in_stock' | t -}}</span>
                          {%- endif -%}
                        {%- endif -%}
                      {%- else -%}
                        {%- if product.selected_or_first_available_variant.inventory_policy == 'continue' -%}
                          <svg width="15" height="15" aria-hidden="true">
                            <circle cx="7.5" cy="7.5" r="7.5" fill="rgb(62,214,96, 0.3)"/>
                            <circle cx="7.5" cy="7.5" r="5" stroke="rgb(255, 255, 255)" stroke-width="1" fill="rgb(62,214,96)"/>
                          </svg>
                          <span>{{- 'products.product.inventory_out_of_stock_continue_selling' | t -}}</span>
                        {%- else -%}
                          <svg width="15" height="15" aria-hidden="true">
                            <circle cx="7.5" cy="7.5" r="7.5" fill="rgb(200,200,200, 0.3)"/>
                            <circle cx="7.5" cy="7.5" r="5" stroke="rgb(255, 255, 255)" stroke-width="1" fill="rgb(200,200,200)"/>
                          </svg>
                          <span>{{- 'products.product.inventory_out_of_stock' | t -}}</span>
                        {%- endif -%}
                      {%- endif -%}
                    {%- endif -%}
                  </div>

                  {%- when 'product_price' -%}
                  <div class="pro-price-label" {{ block.shopify_attributes }}>
                    <div class="price-box" id="price-{{ section.id }}">
                      <span class="new-price" id="ProductPrice">{{ product.selected_or_first_available_variant.price | money }}</span>
                      {%- if product.compare_at_price_max > product.price -%}
                      <span class="old-price" id="ComparePrice">{{ product.selected_or_first_available_variant.compare_at_price | money }}</span>
                      {%- endif -%}
                      <small class="unit-price caption{% if product.selected_or_first_available_variant.unit_price_measurement == nil %} d-none{% endif %}">
                        <span class="price-item price-item--last">
                          <span class="unit-price-unit">{{- product.selected_or_first_available_variant.unit_price | money -}}</span>
                          <span>
                            {%- if product.selected_or_first_available_variant.unit_price_measurement.reference_value != 1 -%}
                              {{- product.selected_or_first_available_variant.unit_price_measurement.reference_value -}}
                            {%- endif -%}
                            {{ product.selected_or_first_available_variant.unit_price_measurement.reference_unit }}
                          </span>
                        </span>
                      </small>
                    </div>
                    {% if settings.sale_percent_enable %}
                    <div
        class="product-label"

        {% if settings.sale_percent_enable
          and product.selected_or_first_available_variant.compare_at_price
            > product.selected_or_first_available_variant.price
          and product.available == true
        %}
          style="display: block;"
        {% else %}
          style="display: none;"
        {% endif %}
      >
        
        <span class="percent-count sale-title" id="ProductDiscount">
          {{-
            product.selected_or_first_available_variant.compare_at_price
            | minus: product.selected_or_first_available_variant.price
            | times: 100.0
            | divided_by: product.selected_or_first_available_variant.compare_at_price
            | money_without_currency
            | replace: ',', '.'
            | times: 100
            | remove: '.0'
          -}}
        </span>
      </div>
                    {% endif %}
                  </div>
                  {%- if block.settings.countdown_enabled and block.settings.countdown_end_date != blank -%}
                    {%- assign cd_today = 'now' | date: '%Y-%m-%d' -%}
                    {%- assign cd_today_ts = cd_today | date: '%s' | plus: 0 -%}
                    {%- assign cd_end_ts = block.settings.countdown_end_date | date: '%s' | plus: 0 -%}
                    {%- assign cd_diff = cd_end_ts | minus: cd_today_ts -%}
                    {%- assign cd_days = cd_diff | divided_by: 86400 -%}
                    {%- if cd_days >= 0 -%}
                      <div class="price-countdown"
                           data-end-date="{{ block.settings.countdown_end_date }}"
                           style="color: {{ block.settings.countdown_text_color }};">
                        <span class="countdown-icon">{{ block.settings.countdown_icon }}</span>
                        <span class="countdown-text">
                          {%- if cd_days == 0 -%}
                            {{ block.settings.countdown_message | replace: '[days] gün', 'gün' | replace: '[days]', '' }}  
                          {%- else -%}
                            {{ block.settings.countdown_message | replace: '[days]', cd_days }}
                          {%- endif -%}
                        </span>
                      </div>
                    {%- endif -%}
                  {%- endif -%}
                  {%- if block.settings.price_advantage_enabled and block.settings.price_advantage_message != blank -%}
                    <div class="price-advantage-message" style="color: {{ block.settings.price_advantage_text_color }};">
                      {%- if block.settings.price_advantage_icon != blank -%}
                        <span class="price-advantage-message__icon">{{ block.settings.price_advantage_icon }}</span>
                      {%- endif -%}
                      <span class="price-advantage-message__text">{{ block.settings.price_advantage_message }}</span>
                    </div>
                  {%- endif -%}
                   
                  {%- when 'short_description' -%}
                  <div class="product-description" {{ block.shopify_attributes }}>
                    <p>{{ block.settings.short_description }}</p>
                  </div>
                  {%- when 'description' -%}
                  {%- if product.description != blank -%}
                    <div class="product-info short-description" {{ block.shopify_attributes }}>
                      {{ product.description }}
                    </div>
                  {%- endif -%}

                  {%- when 'swatch_option' -%}
                  <div class="pro-detail-action" {{ block.shopify_attributes }}>
                   {% render 'product-variant-picker', product: product, block: block, product_form_id: product_form_id %} 
                  </div>
                  {%- comment -%}Mobil CTA altı güven metni — varyantların altına taşındı{%- endcomment -%}
                  {%- if settings.desktop_cta_trust_enable -%}
                    <div class="desktop-cta-trust d-flex d-md-none" style="margin-top: 10px;">
                      {%- if settings.desktop_cta_badge_1_text != blank -%}
                        <span class="trust-item">
                          <span class="trust-icon">{{ settings.desktop_cta_badge_1_icon }}</span>
                          <span>{{ settings.desktop_cta_badge_1_text }}</span>
                        </span>
                      {%- endif -%}
                      {%- if settings.desktop_cta_badge_1_text != blank and settings.desktop_cta_badge_2_text != blank -%}
