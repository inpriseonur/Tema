              </div>
            </li>
            {% endif %}
          </ul>
          {% endif %}
        </div>
        {% endif %}
      </div>
    </div>
  </div>
  <script type="text/javascript">
    (function() {
      var productSection = document.getElementById('MainProduct-{{ section.id }}');
      var packagingVideoMediaId = {{ packaging_video_media_id | json }};
      var productTitleHeading = productSection && productSection.querySelector('[data-product-variant-title]');
      var baseProductTitle = {{ product.title | json }};
      var productInfo = productTitleHeading && productTitleHeading.closest('.product_details_info');
      var priceBlock = productInfo && productInfo.querySelector('.pro-price-label');
      var reviewBlock = productInfo && productInfo.querySelector('.product-title + .product-app-block');
      var salesProofBlock = reviewBlock && reviewBlock.nextElementSibling;

      if (reviewBlock && salesProofBlock && salesProofBlock.classList.contains('product-social-proof-sales')) {
        var socialProofRow = document.createElement('div');
        socialProofRow.className = 'product-social-proof-row';
        reviewBlock.parentNode.insertBefore(socialProofRow, reviewBlock);
        socialProofRow.appendChild(reviewBlock);
        socialProofRow.appendChild(salesProofBlock);
      }

      var titleSpacingAnchor = priceBlock && priceBlock.previousElementSibling;

      if (titleSpacingAnchor && !titleSpacingAnchor.classList.contains('product-title')) {
        titleSpacingAnchor.classList.add('variant-title-spacing-anchor');
      }

      function updateProductVariantTitleSpacing() {
        if (!productTitleHeading || !productInfo || !titleSpacingAnchor) return;
        var lineHeight = parseFloat(window.getComputedStyle(productTitleHeading).lineHeight);
        if (!lineHeight) return;
        var extraHeight = Math.min(Math.max(productTitleHeading.getBoundingClientRect().height - lineHeight, 0), lineHeight);
        productInfo.style.setProperty('--variant-title-line-height', lineHeight + 'px');
        productInfo.style.setProperty('--variant-title-extra-height', extraHeight + 'px');
      }

      function updateProductVariantTitle(variant) {
        if (!productTitleHeading) return;
        var variantOptions = variant && Array.isArray(variant.options)
          ? variant.options.filter(function(option) { return option && option !== 'Default Title'; })
          : [];
        productTitleHeading.textContent = variantOptions.length
          ? baseProductTitle + ' ' + variantOptions.join(' ')
          : baseProductTitle;
        requestAnimationFrame(updateProductVariantTitleSpacing);
      }

      requestAnimationFrame(updateProductVariantTitleSpacing);
      window.addEventListener('resize', updateProductVariantTitleSpacing);

      if (productSection) {
        productSection.addEventListener('change', function(event) {
          var variantPicker = event.target.closest('pr-option, selects-box');
          if (!variantPicker) return;
          setTimeout(function() {
            updateProductVariantTitle(variantPicker.swatch);
          }, 0);
        });
      }

      function trackPackagingVideoEvent(eventName) {
        if (typeof window.gtag !== 'function') return;
        window.gtag('event', eventName, {
          product_id: {{ product.id | json }},
          product_title: {{ product.title | json }},
          video_media_id: packagingVideoMediaId
        });
      }

      function resetDeferredMedia(media) {
        var player = media.querySelector('[data-deferred-product-media-player]');
        if (player) player.replaceChildren();
        media.classList.remove('is-loaded');
      }

      function resetInactiveDeferredMedia(activeSlide) {
        if (!productSection) return;
        productSection.querySelectorAll('[data-deferred-product-media]').forEach(function(media) {
          if (!activeSlide || !activeSlide.contains(media)) resetDeferredMedia(media);
        });
      }

      if (productSection && !productSection.dataset.deferredMediaBound) {
        productSection.dataset.deferredMediaBound = 'true';
        productSection.addEventListener('click', function(event) {
          var button = event.target.closest('[data-deferred-product-media-button]');
          if (!button || !productSection.contains(button)) return;

          var media = button.closest('[data-deferred-product-media]');
          var player = media && media.querySelector('[data-deferred-product-media-player]');
          var template = media && media.querySelector('[data-deferred-product-media-template]');
          if (!media || !player || !template || media.classList.contains('is-loaded')) return;

          player.appendChild(template.content.cloneNode(true));
          media.classList.add('is-loaded');

          if (String(media.dataset.mediaId) === String(packagingVideoMediaId)) {
            trackPackagingVideoEvent('packaging_video_play');
          }

          var video = player.querySelector('video');
          if (video) {
            video.muted = true;
            video.defaultMuted = true;
            var playPromise = video.play();
            if (playPromise && typeof playPromise.catch === 'function') playPromise.catch(function() {});
          }
        });
      }

      setTimeout(function () {
        var mainGalleryElement = productSection && productSection.querySelector('.slider-big-{{ product.id }}');
        var isNormalDesktopGallery = productSection && !productSection.closest('.quickview-block') && window.innerWidth >= 1200;
        var swiperOptions = {
          spaceBetween: 0,
          slidesPerView: 1,
          autoHeight: !isNormalDesktopGallery,
          slideToClickedSlide: true,
          loopedSlides: 50,
          navigation: {
            nextEl: mainGalleryElement && mainGalleryElement.querySelector(".button-next"),
            prevEl: mainGalleryElement && mainGalleryElement.querySelector(".button-prev")
          }
        };

        var selectedVariantInitialSlide = 0;
        {%- if current_variant.featured_media -%}
          var selectedVariantMedia = document.querySelector('#slider-small-{{ product.id }} .swiper-slide[data-image-id="{{ current_variant.featured_media.id }}"]');
          if (selectedVariantMedia) {
            selectedVariantInitialSlide = Math.max(parseInt(selectedVariantMedia.getAttribute('data-index'), 10) - 1, 0);
            swiperOptions.initialSlide = selectedVariantInitialSlide;
          }
        {%- endif -%}

        var quickViewSliderEl = document.querySelector('#slider-small-{{ product.id }}');
        var isQuickView = quickViewSliderEl && quickViewSliderEl.closest('.quickview-block');
        var useVerticalThumbs = !isQuickView && window.innerWidth >= 1200;

        if (window.innerWidth > 749) {
          var swiper = new Swiper(".slider-small-{{ product.id }}", {
            direction: useVerticalThumbs ? "vertical" : "horizontal",
            spaceBetween: useVerticalThumbs ? 10 : 15,
            slidesPerView: useVerticalThumbs ? 3 : 5,
            initialSlide: selectedVariantInitialSlide,
            mousewheel: useVerticalThumbs,
            freeMode: useVerticalThumbs,
            navigation: useVerticalThumbs ? {
              nextEl: ".thumb-button-next",
              prevEl: ".thumb-button-prev"
            } : false,
            breakpoints: {
              0: { slidesPerView: 3 },
              320: { slidesPerView: 3 },
              480: { slidesPerView: 4 },
              1200: { slidesPerView: useVerticalThumbs ? 3 : 4 }
            }
          });
          swiperOptions.thumbs = { swiper: swiper };
        }

        var swiper2 = new Swiper(".slider-big-{{ product.id }}", swiperOptions);
        var mobileMediaCurrent = mainGalleryElement && mainGalleryElement.querySelector('[data-mobile-media-current]');
        var mainGalleryPrev = mainGalleryElement && mainGalleryElement.querySelector('.button-prev');
        var mainGalleryNext = mainGalleryElement && mainGalleryElement.querySelector('.button-next');

        function updateMobileMediaCounter() {
          if (mobileMediaCurrent) mobileMediaCurrent.textContent = swiper2.activeIndex + 1;
        }

        function handleMainGalleryNavigation(event, direction) {
          event.preventDefault();
          event.stopPropagation();
          event.stopImmediatePropagation();
          direction === 'next' ? swiper2.slideNext() : swiper2.slidePrev();
        }

        if (mainGalleryPrev) {
          mainGalleryPrev.addEventListener('click', function(event) {
            handleMainGalleryNavigation(event, 'prev');
          }, true);
        }

        if (mainGalleryNext) {
          mainGalleryNext.addEventListener('click', function(event) {
            handleMainGalleryNavigation(event, 'next');
          }, true);
        }

        updateMobileMediaCounter();
        swiper2.on('slideChange', updateMobileMediaCounter);
        swiper2.on('slideChangeTransitionStart', function() {
          resetInactiveDeferredMedia(swiper2.slides[swiper2.activeIndex]);
        });

        var packagingVideoCtas = productSection ? productSection.querySelectorAll('[data-packaging-video-cta]') : [];
        packagingVideoCtas.forEach(function(packagingVideoCta) {
          packagingVideoCta.addEventListener('click', function() {
            var packagingVideoIndex = parseInt(packagingVideoCta.dataset.packagingVideoIndex, 10);
            if (Number.isNaN(packagingVideoIndex)) return;
            trackPackagingVideoEvent('packaging_video_click');

            var galleryElement = productSection.querySelector('.slider-big-{{ product.id }}');
            var gallerySwiper = galleryElement && galleryElement.swiper ? galleryElement.swiper : swiper2;
            gallerySwiper.slideTo(packagingVideoIndex, 0);

            var videoSlide = gallerySwiper.slides[packagingVideoIndex];
            var playButton = videoSlide && videoSlide.querySelector('[data-deferred-product-media-button]');
            if (playButton) playButton.click();

            var gallery = productSection.querySelector('.product_img_top');
            if (gallery) gallery.scrollIntoView({ behavior: 'smooth', block: 'center' });
          });
        });
        $(".option-block .op-lb").click(function(){
          var op_select = $(this).text();
          $(this).parents('.variant-option-block').find('.current-option').html(op_select);
        });
        var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
        var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
          return new bootstrap.Tooltip(tooltipTriggerEl)
        });
        $('#counter-event-{{ product.id }} span').countdown($('#counter-event-{{ product.id }}').attr("data-enddate"), {defer: true }).on('update.countdown', function(event) {
        var $this = $(this).html(event.strftime('' + '<span>%-D : ' + '%H : ' + '%M : ' + '%S</span>'));
        }).countdown('start');
      },1000);
    })();
    function zoom(e){
      var zoomer = e.currentTarget;
      e.offsetX ? offsetX = e.offsetX : offsetX = e.touches[0].pageX
      e.offsetY ? offsetY = e.offsetY : offsetX = e.touches[0].pageX
      x = offsetX/zoomer.offsetWidth*100
      y = offsetY/zoomer.offsetHeight*100
      zoomer.style.backgroundPosition = x + '% ' + y + '%';
    }
    document.addEventListener('DOMContentLoaded', function () {
      function isIE() {
        const ua = window.navigator.userAgent;
        const msie = ua.indexOf('MSIE ');
        const trident = ua.indexOf('Trident/');
        return msie > 0 || trident > 0;
      }
      if (!isIE()) return;
      const hiddenInput = document.querySelector('#{{ product_form_id }} input[name="id"]');
      const noScriptInputWrapper = document.createElement('div');
      const variantSwitcher =
        document.querySelector('pr-option[data-section="{{ section.id }}"]') ||
        document.querySelector('selects-box[data-section="{{ section.id }}"]');
      noScriptInputWrapper.innerHTML = document.querySelector(
        '.pro-form-noscript-{{ section.id }}'
      ).textContent;
      variantSwitcher.outerHTML = noScriptInputWrapper.outerHTML;

      document.querySelector('#Variants-{{ section.id }}').addEventListener('change', function (event) {
        hiddenInput.value = event.currentTarget.value;
      });
    });
    /* Geri sayım: cache durumunda doğru gün hesaplama */
    (function() {
      var countdowns = document.querySelectorAll('.price-countdown, .qty-countdown-mobile');
      countdowns.forEach(function(el) {
        var endDate = el.getAttribute('data-end-date');
        if (!endDate) return;
        var now = new Date();
        var today = new Date(now.getFullYear(), now.getMonth(), now.getDate());
        var parts = endDate.split('-');
        var end = new Date(parseInt(parts[0]), parseInt(parts[1]) - 1, parseInt(parts[2]));
        var diff = Math.round((end - today) / (1000 * 60 * 60 * 24));
        if (diff < 0) {
          el.style.display = 'none';
          var fallbackEl = el.nextElementSibling;
          if (fallbackEl && fallbackEl.classList.contains('price-advantage-mobile--fallback')) {
            fallbackEl.style.display = 'flex';
          }
        } else {
          var hiddenFallbackEl = el.nextElementSibling;
          if (hiddenFallbackEl && hiddenFallbackEl.classList.contains('price-advantage-mobile--fallback')) {
            hiddenFallbackEl.style.display = 'none';
          }
          var textEl = el.querySelector('.countdown-text');
          if (textEl) {
            if (diff === 0) {
              textEl.textContent = textEl.textContent.replace(/son\s*\d+\s*gün/, 'son gün').replace(/\d+\s*gün/, 'gün');
            } else {
              textEl.textContent = textEl.textContent.replace(/\d+/, diff);
            }
          }
        }
      });
    })();
  </script>
</section>
