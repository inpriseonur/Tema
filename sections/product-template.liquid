                          <span class="trust-icon">{{ settings.desktop_cta_badge_2_icon }}</span>
                          <span>{{ settings.desktop_cta_badge_2_text }}</span>
                        </span>
                      {%- endif -%}
                      {%- if settings.desktop_cta_badge_2_text != blank and settings.desktop_cta_badge_3_text != blank -%}
                        <span class="trust-separator">·</span>
                      {%- endif -%}
                      {%- if settings.desktop_cta_badge_3_text != blank -%}
