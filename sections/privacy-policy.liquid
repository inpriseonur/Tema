<section class="section-ptb other-page">
  <div class="container">
    <div class="row">
      <div class="col">
        <div class="content-main-title">
          {% if section.settings.privacy_policy_title != '' %}
          <h2>{{ section.settings.privacy_policy_title }}</h2>
          {% endif %}
        </div>
        <div class="rule-wrap">
          <ul>
            {{ page.content }}
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Privacy Policy",
  "settings": [
  {
    "type": "header",
    "content": "Page Title"
  },
  {
    "type": "text",
    "id": "privacy_policy_title",
    "label": "Title",
    "default": "Privacy Policy"
  }
  ]
}
{% endschema %}
<style type="text/css">
.other-page .rule-wrap ul{
  list-style: disc;
  padding-left: 25px;
}
.other-page .rule-wrap ul li{
  margin-bottom: 15px;
}
.other-page .rule-wrap ul li:last-child{
  margin-bottom: 0px;
}
@media (max-width : 767px){
  .other-page .rule-wrap ul{
    padding-left: 20px;
  }
  .other-page .rule-wrap ul li{
    margin-bottom: 10px;
  }
}
</style>