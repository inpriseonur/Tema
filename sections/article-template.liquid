    font-size: 18px;
    font-weight: 600;
  }
  .single-blog-area .blog-revert ul.blogger-info {
    display: flex;
    align-items: center;
    margin-top: 6px;
  }
  .single-blog-area .blog-revert ul.blogger-info li {
