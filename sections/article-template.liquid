<section class="article-area section-ptb">
  <div class="container">
    <div class="row {% if section.settings.sidebar_handle == 'left_sidebar_handle' %}left-wrap{% elsif section.settings.sidebar_handle == 'right_sidebar_handle' %}right-wrap{% endif %}">
      <div class="{% if section.settings.sidebar_handle == 'without_sidebar' %}col{% else %}col-xl-9 col-lg-8 col-md-8 col-12 blog-article-wrap{% endif %}">
        <div class="single-blog-area">
          <div class="blog-image">
            <a href="{{ article.url }}">
              {%- if article.image -%}
              <img srcset="
              {%- if article.image.width >= 375 -%}{{ article.image | image_url: width: 375 }} 375w,{%- endif -%}
              {%- if article.image.width >= 550 -%}{{ article.image | image_url: width: 550 }} 550w,{%- endif -%}
              {%- if article.image.width >= 750 -%}{{ article.image | image_url: width: 750 }} 750w,{%- endif -%}
              {%- if article.image.width >= 1100 -%}{{ article.image | image_url: width: 1100 }} 1100w,{%- endif -%}
              {%- if article.image.width >= 1500 -%}{{ article.image | image_url: width: 1500 }} 1500w,{%- endif -%}
              {%- if article.image.width >= 1780 -%}{{ article.image | image_url: width: 1780 }} 1780w,{%- endif -%}
              {%- if article.image.width >= 2000 -%}{{ article.image | image_url: width: 2000 }} 2000w,{%- endif -%}
              {{ article.image | image_url }} {{ article.image.width }}w
              "
              src="{{ article.image | image_url: width: 2000 }}"
              data-src="{{ article.image | image_url: width: 2000 }}"
              alt="{{ article.image.alt | escape }}"
              class="img-fluid lazyload desk-img lazyload"
              width="{{ article.image.width }}"
              height="{{ article.image.width | divided_by: article.image.aspect_ratio }}"
              decoding="async"
              loading="lazy"
              sizes="100vw">
              {%- else -%}
              {%- capture placeholder -%}hero-apparel-{% cycle 1, 2, 3 %}{%- endcapture -%}
              {{ placeholder | placeholder_svg_tag: 'placeholder-svg desk-img' }}
              {%- endif -%}
            </a>
          </div>
          <div class="blog-revert">
            <h2 class="post-title">{{ article.title }}</h2>
            <ul class="blogger-info">
              <li>
                <span class="blog-off date-time">
                  <i class="icon-clock"></i>
                  <span>{{ article.published_at | date: '%b %d, %Y' }}</span>
                </span>
              </li>
              <li>
                <span class="blog-off blog-author">
                  <i class="icon-user"></i>
                  <span>{{ section.settings.article_through }}</span>
                  <span>{{ article.author | truncatewords: 2 | remove: "." }}</span>
                </span>
              </li>
              <li>
                <span class="blog-off blog-comment">
                  <i class="icon-bubble"></i>
                  <span>{{ article.comments_count }}</span>
                  <span>{{ section.settings.article_cmt }}</span>
                </span>
              </li>
            </ul>
          </div>
          <div class="blog-content">
            {{ article.content }}
          </div>
          <div class="post-info">
            <blockquote>
              <i class="fa fa-quote-left"></i>
              <h2 class="post-title">{{ article.title }}</h2>
              <span class="post-author">{{ article.author | truncatewords: 2 | remove: "." }}</span>
            </blockquote>
          </div>
          <div class="post-info-tag">
            <ul class="post-tag">
              {% for tag in article.tags %}
              <li>{{ tag | link_to_tag: tag }}</li>
              {% endfor %}
            </ul>
          </div>
          <div class="blog-share">
            {% include 'social-share-blog' %}
          </div>
          {% if article.comments_enabled? %}
          {% assign comment_post_limit = section.settings.comment_post_limit_handle %}
          {% paginate article.comments by comment_post_limit %}
          <div id="comments" class="blog-comments">
            {% if article.comments.size > 0 %}
            {% include 'blog-comments' %}
            {% endif %}
            {% if paginate.pages > 1 %}
            <div class="paginatoin-area">
              {%- include 'pagination' -%}
            </div>
            {% endif %}
            {% endpaginate %}
            <div class="blog-comment-form">
              {% include 'blog-comment-form' %}
            </div>
          </div>
          {% endif %}
        </div>
      </div>
      {% unless section.settings.sidebar_handle == 'without_sidebar' %}
      <div class="col-xl-3 col-lg-4 col-md-4 col-12 blog-article-wrap">
        {% include 'blog-sidebar' %}
      </div>
      {% endunless %}
    </div>
  </div>
</section>

