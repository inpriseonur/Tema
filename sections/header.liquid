<style>
  .header-area .header-main-area {
    background-color: {{ section.settings.header_bgcolor }};
  }
  {%- if template == 'index' or template == 'product' or template == 'collection' -%}
  .header-area.is-sticky{
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 8;
    width: 100%;
    box-shadow: 0 0 15px rgb(0 0 0 / 15%);
    -webkit-box-shadow: 0 0 15px rgb(0 0 0 / 15%);
    -moz-box-shadow: 0 0 15px rgba(0, 0, 0, 0.15);
    -ms-box-shadow: 0 0 15px rgba(0, 0, 0, 0.15);
    background-color: #fff;
    animation: smoothScroll 1s forwards;
    background-color: #fff;
  }
  @keyframes smoothScroll {
    0% {
      transform: translateY(-150px);
    }
    100% {
      transform: translateY(0px);
    }
  }
  {%- endif -%}
  ul.shop-element .user-wrap .acc-desk a.acc-ti,
  ul.shop-element .wishlist-wrap .wishlist a,
  ul.shop-element .cart-wrap .shopping-cart a.cart-count {
    color: {{ section.settings.header_icon_color }};
  }
  .main-menu-area {
    background-color: {{ section.settings.header_bottom_bgcolor }};
    border-top: 1px solid rgba(0, 0, 0, 0.08);
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
  }
  .main-menu-area ul.main-menu li.menu-link a.link-title {
    color: {{ section.settings.header_text_color }};
    font-weight: 600;
    transition: color 0.2s ease-in-out;
  }
  @media (min-width: 1200px) {
    .header-area .header-main {
      padding: 14px 0;
      border-top: 0;
    }
    .header-area .header-main-area {
      border-bottom: 1px solid rgba(6, 31, 70, 0.06);
    }
    .header-area.is-sticky {
      border-bottom: 1px solid rgba(6, 31, 70, 0.08);
      box-shadow: 0 10px 28px rgba(6, 31, 70, 0.08);
      -webkit-box-shadow: 0 10px 28px rgba(6, 31, 70, 0.08);
      -moz-box-shadow: 0 10px 28px rgba(6, 31, 70, 0.08);
      -ms-box-shadow: 0 10px 28px rgba(6, 31, 70, 0.08);
    }
    .header-area .search-wrap .field input {
      height: 44px;
      padding: 0 48px 0 18px;
      border: 1px solid transparent;
      border-radius: 4px;
      background-color: #eef6f6;
      transition: border-color 0.2s ease, box-shadow 0.2s ease, background-color 0.2s ease;
    }
    .header-area .search-wrap .field input:focus {
      border-color: rgba(190, 146, 75, 0.55);
      background-color: #fff;
      box-shadow: 0 0 0 3px rgba(190, 146, 75, 0.10);
      outline: 0;
    }
    .header-area .search-wrap .field button.search-btn {
      right: 17px;
      color: var(--font-color-header);
      transition: color 0.2s ease, transform 0.2s ease;
    }
    .header-area .search-wrap .field button.search-btn:hover {
      color: #be924b;
      transform: translateY(-1px);
    }
    .header-area ul.shop-element li.ele-wrap:not(.search-wrap) {
      margin-left: 22px;
    }
    .header-area ul.shop-element .user-wrap .acc-desk a.acc-ti,
    .header-area ul.shop-element .wishlist-wrap .wishlist a,
    .header-area ul.shop-element .cart-wrap .shopping-cart a.cart-count {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 34px;
      height: 34px;
      border-radius: 50%;
      transition: color 0.2s ease, background-color 0.2s ease, transform 0.2s ease;
    }
    .header-area ul.shop-element .user-wrap .acc-desk a.acc-ti:hover,
    .header-area ul.shop-element .wishlist-wrap .wishlist a:hover,
    .header-area ul.shop-element .cart-wrap .shopping-cart a.cart-count:hover {
      color: #be924b;
      background-color: rgba(190, 146, 75, 0.10);
      transform: translateY(-1px);
    }
    .header-area ul.shop-element .wishlist-wrap .wishlist a i,
    .header-area ul.shop-element .cart-wrap .shopping-cart a.cart-count i {
      margin-right: 0;
    }
    .header-area ul.shop-element .wishlist-wrap .wishlist a span,
    .header-area ul.shop-element .cart-wrap .shopping-cart a.cart-count span {
      top: -4px;
      right: -2px;
      width: 18px;
      height: 18px;
      font-size: 11px;
      box-shadow: 0 2px 6px rgba(6, 31, 70, 0.18);
    }
    .main-menu-area {
      border-bottom: 1px solid rgba(6, 31, 70, 0.06);
    }
    .main-menu-area .main-navigation {
      min-height: 48px;
    }
    .main-menu-area ul.main-menu li.menu-link a.link-title {
      padding-top: 14px;
      padding-bottom: 14px;
      font-weight: 600;
      transition: color 0.2s ease;
    }
    .main-menu-area ul.main-menu li.menu-link a.link-title:hover,
    .main-menu-area ul.main-menu li.menu-link a.link-title:hover .sp-link-title,
    .main-menu-area ul.main-menu li.menu-link a.link-title.is-active,
    .main-menu-area ul.main-menu li.menu-link a.link-title .sp-link-title.active {
      color: #be924b;
    }
  }

  .main-menu-area ul.main-menu li.menu-link a.link-title .sp-link-title {
    position: relative;
    display: inline-flex;
    align-items: center;
  }
  .main-menu-area ul.main-menu li.menu-link a.link-title .sp-link-title::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: -14px;
    height: 2px;
    background-color: {{ section.settings.menu_active_color }};
    opacity: 0;
    transform: scaleX(0);
    transform-origin: left center;
    transition: opacity 0.2s ease-in-out, transform 0.2s ease-in-out;
  }
  .main-menu-area ul.main-menu li.menu-link a.link-title:hover,
  .main-menu-area ul.main-menu li.menu-link a.link-title:hover .sp-link-title,
  .main-menu-area ul.main-menu li.menu-link a.link-title .sp-link-title.active {
    color: {{ section.settings.menu_active_color }};
  }
  .main-menu-area ul.main-menu li.menu-link a.link-title:hover .sp-link-title::after,
  .main-menu-area ul.main-menu li.menu-link a.link-title .sp-link-title.active::after {
    opacity: 1;
    transform: scaleX(1);
  }
  .main-menu-area .main-navigation {
    min-height: 51px;
    justify-content: space-between;
    gap: 20px;
  }
  .main-menu-area .main-navigation > nav.mainwrap {
    flex: 1 1 auto;
    width: auto;
    min-width: 0;
  }
  .main-menu-area .nav-action-group {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    gap: 18px;
    margin-right: 28px;
    white-space: nowrap;
  }
  .main-menu-area .nav-instagram-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    height: 34px;
    line-height: 1;
    color: {{ section.settings.nav_instagram_cta_text_color }};
    font-size: 14px;
    font-weight: 700;
    text-decoration: none;
    transition: color 0.2s ease-in-out, transform 0.2s ease-in-out;
  }
  .main-menu-area .nav-instagram-cta__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: {{ section.settings.nav_instagram_cta_icon_color }};
    font-size: 18px;
    line-height: 1;
    transition: color 0.2s ease-in-out;
  }
  .main-menu-area .nav-instagram-cta:hover {
    color: {{ section.settings.nav_instagram_cta_hover_color }};
    transform: translateY(-1px);
  }
  .main-menu-area .nav-instagram-cta:hover .nav-instagram-cta__icon {
    color: {{ section.settings.nav_instagram_cta_hover_color }};
  }
  .main-menu-area .nav-trust-badge {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    gap: 9px;
    height: 34px;
    line-height: 1;
    white-space: nowrap;
    margin-right: 0;
  }
  .main-menu-area .nav-trust-badge__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: {{ section.settings.nav_trust_badge_icon_color }};
    font-size: 17px;
    line-height: 1;
  }
  .main-menu-area .nav-trust-badge__content {
    display: inline-flex;
    align-items: baseline;
    gap: 8px;
  }
  .main-menu-area .nav-trust-badge__title {
    color: {{ section.settings.nav_trust_badge_title_color }};
    font-size: 14px;
    font-weight: 700;
  }
  .main-menu-area .nav-trust-badge__title-link {
    text-decoration: none;
    transition: color 0.2s ease-in-out;
  }
  .main-menu-area .nav-trust-badge__title-link:hover {
    color: {{ section.settings.nav_trust_badge_icon_color }};
  }
  .main-menu-area .nav-trust-badge__text {
    color: {{ section.settings.nav_trust_badge_text_color }};
    font-size: 13px;
    font-weight: 500;
  }
  .header-area ul.shop-element li.ele-wrap.search-wrap {
    max-width: 520px;
  }
  .header-area .search-wrap .field input {
    height: 40px;
    padding: 9px 44px 9px 15px;
    border: 1px solid rgba(20, 40, 80, 0.12);
    border-radius: 6px;
    color: {{ section.settings.header_icon_color }};
    background-color: #fff;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.8);
  }
  .header-area .search-wrap .field input::placeholder {
    color: rgba(20, 40, 80, 0.48);
  }
  .header-area .search-wrap .field button {
    right: 14px;
    color: {{ section.settings.header_icon_color }};
  }
  @media (max-width: 1199px) {
    .main-menu-area .nav-action-group {
      display: none;
    }
  }
  @media (min-width: 1200px) and (max-width: 1399px) {
    .main-menu-area .nav-action-group {
      gap: 14px;
      margin-right: 18px;
    }
    .main-menu-area .nav-instagram-cta {
      gap: 7px;
      font-size: 13px;
    }
    .main-menu-area .nav-instagram-cta__icon {
      font-size: 17px;
    }
    .main-menu-area .nav-trust-badge {
      gap: 7px;
    }
    .main-menu-area .nav-trust-badge__title {
      font-size: 13px;
    }
    .main-menu-area .nav-trust-badge__text {
      font-size: 12px;
    }
  }
</style>
