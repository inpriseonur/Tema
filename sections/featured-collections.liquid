{%- liquid
  assign visible_blocks = 0
  for block in section.blocks
    if block.settings.collection != blank or block.settings.image != blank
      assign visible_blocks = visible_blocks | plus: 1
    endif
  endfor
-%}

{%- if visible_blocks > 0 or request.design_mode -%}
  <section class="featured-collections-section">
    <div class="container">
      {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
        <div class="featured-collections__header">
          {%- if section.settings.heading != blank -%}
            <h2>{{ section.settings.heading }}</h2>
          {%- endif -%}
          {%- if section.settings.subheading != blank -%}
            <p>{{ section.settings.subheading }}</p>
          {%- endif -%}
        </div>
      {%- endif -%}

      <div class="featured-collections__grid" role="list">
        {%- for block in section.blocks -%}
          {%- assign featured_collection = block.settings.collection -%}
          {%- if featured_collection != blank or block.settings.image != blank -%}
            {%- liquid
              assign card_image = block.settings.image
              if card_image == blank and featured_collection != blank
                assign card_image = featured_collection.image
              endif
              if card_image == blank and featured_collection != blank
                assign card_image = featured_collection.products.first.featured_image
              endif

              assign card_title = block.settings.title
              if card_title == blank and featured_collection != blank
                assign card_title = featured_collection.title
              endif

              assign card_url = block.settings.link
              if card_url == blank and featured_collection != blank
                assign card_url = featured_collection.url
              endif

              assign card_alt = card_image.alt
              if card_alt == blank
                assign card_alt = card_title
              endif
            -%}

            <{% if card_url != blank %}a{% else %}div{% endif %}
              class="featured-collections__card{% if card_url == blank %} featured-collections__card--unlinked{% endif %}"
              {% if card_url != blank %}href="{{ card_url }}"{% endif %}
              role="listitem"
              {% if card_url != blank and card_title != blank %}aria-label="{{ card_title | escape }}"{% endif %}
              {{ block.shopify_attributes }}
            >
              <span class="featured-collections__media">
                {%- if card_image != blank -%}
                  {{
                    card_image
                    | image_url: width: 1200
                    | image_tag:
                      widths: '360, 480, 600, 720, 900, 1200',
                      sizes: '(min-width: 1200px) 370px, (min-width: 768px) 30vw, 82vw',
                      loading: 'lazy',
                      decoding: 'async',
                      class: 'featured-collections__image',
                      alt: card_alt
                  }}
                {%- else -%}
                  {{ 'collection-apparel-1' | placeholder_svg_tag: 'featured-collections__placeholder' }}
                {%- endif -%}
              </span>

              {%- if card_title != blank or block.settings.text != blank or card_url != blank and section.settings.show_link_text and block.settings.link_text != blank -%}
                <span class="featured-collections__content">
                  {%- if card_title != blank -%}
                    <strong>{{ card_title }}</strong>
                  {%- endif -%}
                  {%- if block.settings.text != blank -%}
                    <span>{{ block.settings.text }}</span>
                  {%- endif -%}
                  {%- if card_url != blank and section.settings.show_link_text and block.settings.link_text != blank -%}
                    <span class="featured-collections__link-text">{{ block.settings.link_text }}</span>
                  {%- endif -%}
                </span>
              {%- endif -%}
            </{% if card_url != blank %}a{% else %}div{% endif %}>
          {%- elsif request.design_mode -%}
            <div class="featured-collections__card featured-collections__card--empty" role="listitem" {{ block.shopify_attributes }}>
              <span class="featured-collections__media">
                {{ 'collection-apparel-1' | placeholder_svg_tag: 'featured-collections__placeholder' }}
              </span>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </section>
{%- endif -%}

{% style %}
  #shopify-section-{{ section.id }} .featured-collections-section {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background: {{ section.settings.background_color }};
  }

  #shopify-section-{{ section.id }} .featured-collections__header {
    margin-bottom: 24px;
    text-align: {{ section.settings.heading_alignment }};
  }

  #shopify-section-{{ section.id }} .featured-collections__header h2 {
    margin: 0;
    color: {{ section.settings.heading_color }};
  }

  #shopify-section-{{ section.id }} .featured-collections__header p {
    max-width: 680px;
    margin: 8px {% if section.settings.heading_alignment == 'center' %}auto{% else %}0{% endif %} 0;
    color: {{ section.settings.text_color }};
    line-height: 1.5;
  }

  #shopify-section-{{ section.id }} .featured-collections__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: {{ section.settings.gap }}px;
  }

  #shopify-section-{{ section.id }} .featured-collections__card {
    position: relative;
    display: block;
    min-width: 0;
    overflow: hidden;
    border: 1px solid {{ section.settings.border_color }};
    border-radius: {{ section.settings.border_radius }}px;
    color: inherit;
    background: {{ section.settings.card_background_color }};
    box-shadow: 0 6px 20px rgba(6, 31, 79, 0.06);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  #shopify-section-{{ section.id }} .featured-collections__media {
    position: relative;
    display: block;
    overflow: hidden;
    aspect-ratio: 4 / 3;
    background: #f5f5f5;
  }

  #shopify-section-{{ section.id }} .featured-collections__image,
  #shopify-section-{{ section.id }} .featured-collections__placeholder {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  #shopify-section-{{ section.id }} .featured-collections__image {
    transition: transform 0.25s ease;
  }

  #shopify-section-{{ section.id }} .featured-collections__content {
    display: flex;
    flex-direction: column;
    gap: 5px;
    padding: 16px 18px 18px;
  }

  #shopify-section-{{ section.id }} .featured-collections__content strong {
    color: {{ section.settings.heading_color }};
    font-size: 18px;
    font-weight: 600;
    line-height: 1.25;
  }

  #shopify-section-{{ section.id }} .featured-collections__content > span:not(.featured-collections__link-text) {
    color: {{ section.settings.text_color }};
    font-size: 13px;
    line-height: 1.45;
  }

  #shopify-section-{{ section.id }} .featured-collections__link-text {
    margin-top: 5px;
    color: {{ section.settings.link_color }};
    font-size: 13px;
    font-weight: 600;
    line-height: 1.3;
  }

  #shopify-section-{{ section.id }} .featured-collections__card:focus-visible {
    outline: 2px solid {{ section.settings.link_color }};
    outline-offset: 3px;
  }

  @media (hover: hover) and (min-width: 992px) {
    #shopify-section-{{ section.id }} .featured-collections__card:hover {
      transform: translateY(-3px);
      box-shadow: 0 10px 26px rgba(6, 31, 79, 0.1);
    }

    #shopify-section-{{ section.id }} .featured-collections__card:hover .featured-collections__image {
      transform: scale(1.025);
    }
  }

  @media (max-width: 991px) {
    #shopify-section-{{ section.id }} .featured-collections__grid {
      gap: 16px;
    }

    #shopify-section-{{ section.id }} .featured-collections__content {
      padding: 14px 14px 16px;
    }

    #shopify-section-{{ section.id }} .featured-collections__content strong {
      font-size: 16px;
    }
  }

  @media (max-width: 767px) {
    #shopify-section-{{ section.id }} .featured-collections-section {
      padding-top: {{ section.settings.mobile_padding_top }}px;
      padding-bottom: {{ section.settings.mobile_padding_bottom }}px;
    }

    #shopify-section-{{ section.id }} .featured-collections__header {
      margin-bottom: 18px;
    }

    #shopify-section-{{ section.id }} .featured-collections__grid {
      grid-template-columns: none;
      grid-auto-flow: column;
      grid-auto-columns: minmax(78%, 1fr);
      gap: 12px;
      margin-right: -12px;
      padding-right: 12px;
      overflow-x: auto;
      overscroll-behavior-inline: contain;
      scroll-snap-type: inline mandatory;
      scrollbar-width: none;
      -webkit-overflow-scrolling: touch;
    }

    #shopify-section-{{ section.id }} .featured-collections__grid::-webkit-scrollbar {
      display: none;
    }

    #shopify-section-{{ section.id }} .featured-collections__card {
      scroll-snap-align: start;
    }

    #shopify-section-{{ section.id }} .featured-collections__content {
      gap: 4px;
      padding: 13px 14px 15px;
    }

    #shopify-section-{{ section.id }} .featured-collections__content strong {
      font-size: 15px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #shopify-section-{{ section.id }} .featured-collections__card,
    #shopify-section-{{ section.id }} .featured-collections__image {
      transition: none;
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "Koleksiyon Vitrini",
  "tag": "section",
  "class": "section-featured-collections",
  "max_blocks": 3,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Başlık",
      "default": "Kategorileri keşfedin"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Alt açıklama"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Başlık hizası",
      "options": [
        {
          "value": "left",
          "label": "Sol"
        },
        {
          "value": "center",
          "label": "Orta"
        }
      ],
      "default": "left"
    },
    {
      "type": "checkbox",
      "id": "show_link_text",
      "label": "Bağlantı metnini göster",
      "default": true
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Kartlar arası boşluk",
      "min": 12,
      "max": 36,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Köşe yuvarlaklığı",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "header",
      "content": "Boşluklar"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Üst boşluk",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 35
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Alt boşluk",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 35
    },
    {
      "type": "range",
      "id": "mobile_padding_top",
      "label": "Mobil üst boşluk",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 25
    },
    {
      "type": "range",
      "id": "mobile_padding_bottom",
      "label": "Mobil alt boşluk",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 25
    },
    {
      "type": "header",
      "content": "Renkler"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Bölüm arka planı",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_background_color",
      "label": "Kart arka planı",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Kart kenarlığı",
      "default": "#ececec"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Başlık rengi",
      "default": "#142850"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Metin rengi",
      "default": "#666666"
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "Bağlantı rengi",
      "default": "#b79659"
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Koleksiyon",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Koleksiyon"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Vitrin görseli",
          "info": "Önerilen: 1200 x 900 px WebP. Boş bırakılırsa koleksiyon görseli kullanılır."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Tıklama bağlantısı",
          "info": "Koleksiyon, ürün, sayfa veya özel URL seçilebilir. Boş bırakılırsa seçili koleksiyonun bağlantısı kullanılır."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Özel başlık",
          "info": "Boş bırakılırsa koleksiyon başlığı kullanılır."
        },
        {
          "type": "text",
          "id": "text",
          "label": "Kısa açıklama"
        },
        {
          "type": "text",
          "id": "link_text",
          "label": "Bağlantı metni",
          "default": "Ürünleri incele"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Koleksiyon Vitrini",
      "blocks": [
        {
          "type": "collection"
        },
        {
          "type": "collection"
        },
        {
          "type": "collection"
        }
      ]
    }
  ]
}
{% endschema %}
