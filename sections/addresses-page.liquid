}
.my-account-page .address-wrap ul.cust-address-wrap li.cust-address .cust-add-wrap p.edit-address-button a:last-child {
  border-radius: 0px 5px 5px 0px;
}
.my-account-page .address-wrap ul.cust-address-wrap li.cust-address .cust-add-wrap p.edit-address-button a:hover {
  
}
.my-account-page .address-wrap ul.cust-address-wrap li.cust-address a.add-more-add {
  
  height: 100%;
  width: 100%;
