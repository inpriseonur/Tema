<div class="product-area">
  <div class="container">
    <div class="row">
      <div class="col-xl-12 col-lg-12 col-md-12 col-12">
        <div class="section-title">
          {% if section.settings.section_title !='' %}
          <h2>{{ section.settings.section_title }}</h2>
          {% endif %}
        </div>
        <div class="tab">
          <ul class="nav nav-tabs" role="tablist">
            {% for block in section.blocks %}
            {% case block.type %}
            {% when 'product_tab' %}
            {% assign category_product = collections[block.settings.tab_product] %}
            <li role="presentation">
              <a class="{% if forloop.first == true %}active show{% endif %}" role="tab" data-bs-toggle="tab" href="#tab-{{ block.id }}">{{ category_product.title }}</a>
            </li>
            {% endcase %}
            {% endfor %}
          </ul>
          <div class="tab-content tabs">
            {% for block in section.blocks %}
            {% case block.type %}
            {% when 'product_tab' %}
            <div class="tab-pane fade{% if forloop.first == true %} active show{% endif %}" id="tab-{{ block.id }}" role="tabpanel">
              <div class="pro-tab-slider swiper" id="pro-tab-{{ block.id }}">
                <div class="swiper-wrapper">
                  {% for product in collections[block.settings.tab_product].products %}
                  <div class="swiper-slide">
                    {% render 'product-grid-item',product: product, section_id: section.id  %}
                  </div>
                  {% endfor %}
                </div>
              </div>
              <div class="swiper-buttons product-tab-buttons">
                <button type="button" class="button-prev product-tab-button-prev-{{ block.id }}" aria-label="Önceki ürün"></button>
                <button type="button" class="button-next product-tab-button-next-{{ block.id }}" aria-label="Sonraki ürün"></button>
              </div>
            </div>
            <script>
            addEventListener('DOMContentLoaded', (event) => {
              var swiper = new Swiper('#pro-tab-{{ block.id }}', {
                slidesPerView: {{ section.settings.slide_product_limit }},
                grid: {
                  rows: {{ section.settings.product_col }},
                  fill: 'row' | 'column',
                },
                spaceBetween: 30,
                observer: true,
                observeParents: true,
                {%- if settings.enable_rtl -%}
                rtl: true,
                {%- endif -%}
                navigation: {
                  nextEl: '.product-tab-button-next-{{ block.id }}',
                  prevEl: '.product-tab-button-prev-{{ block.id }}',
                },
                breakpoints: {
                  0: {
                    slidesPerView: 1,
                    grid: {
                      rows: {{ section.settings.product_col }},
                      fill: 'row' | 'column',
                    },
                    spaceBetween: 12
                  },
                  320: {
                    slidesPerView: 1,
                    grid: {
                      rows: {{ section.settings.product_col }},
                      fill: 'row' | 'column',
                    },
                    spaceBetween: 12
                  },
                  360: {
                    slidesPerView: 2,
                    grid: {
                      rows: {{ section.settings.product_col }},
                      fill: 'row' | 'column',
                    },
                    spaceBetween: 12
                  },
                  540: {
                    slidesPerView: 2,
                    grid: {
                      rows: {{ section.settings.product_col }},
                      fill: 'row' | 'column',
                    },
                    spaceBetween: 12
                  },
                  640: {
                    slidesPerView: 2,
                    grid: {
                      rows: {{ section.settings.product_col }},
                      fill: 'row' | 'column',
                    },
                    spaceBetween: 12
                  },
                  768: {
                    slidesPerView: 2,
                    grid: {
                      rows: {{ section.settings.product_col }},
                      fill: 'row' | 'column',
                    },
                    spaceBetween: 30
                  },
                  1024: {
                    slidesPerView: 3,
                    grid: {
                      rows: {{ section.settings.product_col }},
                      fill: 'row' | 'column',
                    },
                    spaceBetween: 30
                  },
                  1199: {
                    slidesPerView: {{ section.settings.slide_product_limit }},
                    grid: {
                      rows: {{ section.settings.product_col }},
                      fill: 'row' | 'column',
                    },
                    spaceBetween: 30
                  }
                }
              });
            });
            </script>
            {% endcase %}
            {% endfor %}
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
{% schema %}
{
  "name": "Product Tab Slider",
  "settings": [
  {
      "type": "header",
      "content": "Section Padding"
  },
  {
      "type": "range",
      "id": "section_padding_top",
      "label": "Section Padding Top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 80
  },
  {
      "type": "range",
      "id": "section_padding_bottom",
      "label": "Section Padding Bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 80
  },
  {
      "type" : "paragraph",
      "content" : "Mobile"
  },
  {
      "type": "range",
      "id": "section_padding_top_xs",
      "label": "Section Padding Top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 50
  },
  {
      "type": "range",
      "id": "section_padding_bottom_xs",
      "label": "Section Padding Bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 50
  },
  {
    "type": "header",
    "content": "Section Heading"
  },
  {
    "type": "text",
    "id": "section_title",
    "label": "Section Title",
    "default": "Featured Products"
  },
  {
    "type": "header",
    "content": "Product"
  },
  {
    "type": "select",
    "id": "product_col",
    "label": "Slides Per Column",
    "options":[
    {
      "label": "1 Products",
      "value": "1"
    },
    {
      "label": "2 Products",
      "value": "2"
    },
    {
      "label": "3 Products",
      "value": "3"
    }
    ],
    "default": "1"
  },
  {
    "type": "select",
    "id": "slide_product_limit",
    "label": "slides Per View",
    "options":[
    {
      "label": "2 Products",
      "value": "2"
    },
    {
      "label": "3 Products",
      "value": "3"
    },
    {
      "label": "4 Products",
      "value": "4"
    }
    ],
    "default": "4"
  },
  {
    "type": "text",
    "id": "featured_product_limit_handle",
    "label": "Product Limit",
    "default": "10"
  },
  {
    "type": "color",
    "id": "pro_tab_bg_color", 
    "label": "Background Color",
    "default":   "#fff"
  }
  ],
  "blocks" : [
  {
    "type" : "product_tab",
    "name" : "Our Product",
    "limit" : 3,
    "settings" : [
    {
      "type" : "collection",
      "id" : "tab_product",
      "label" : "Tab With Product"
    }
    ]
  }
  ],
  "presets": [
  {
    "name": "Featured Product Tab Slider"
  }
  ]
}
{% endschema %}
<style>
  .product-area {
    padding-top: {{ section.settings.section_padding_top }}px;
      padding-bottom: {{ section.settings.section_padding_bottom }}px;
  }
  @media(max-width: 1199px) {
      .product-area {
          padding-top: {{ section.settings.section_padding_top_xs }}px;
          padding-bottom: {{ section.settings.section_padding_bottom_xs }}px;
      }
  }
  .product-area ul.nav-tabs{
    margin-bottom: 30px;
    justify-content: center;
    border-bottom: 0;
    gap: 10px 24px;
  }
  .product-area ul.nav-tabs li a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 34px;
    padding: 8px 14px;
    border: 1px solid transparent;
    border-radius: 4px;
    color: #8f8f8f;
    font-size: 13px;
    font-weight: 700;
    line-height: 1.1;
    text-transform: uppercase;
    transition: color 0.2s ease, border-color 0.2s ease, background-color 0.2s ease;
  }
  .product-area ul.nav-tabs li a.active,
  .product-area ul.nav-tabs li a:hover {
    color: #061f4f;
    border-color: #061f4f;
    background-color: #fff;
  }
  @media(max-width: 767px){
    .product-area ul.nav-tabs{
      margin-bottom: 20px;
      gap: 8px;
    }
    .product-area ul.nav-tabs li a {
      min-height: 32px;
      padding: 7px 10px;
      font-size: 11px;
    }
  }

  .product-area .single-product-wrap .product-content {
    text-align: left;
  }

  .product-area .single-product-wrap .product-content .product-title a {
    display: -webkit-box;
    height: 39px;
    overflow: hidden;
    color: #061f4f;
    font-size: 14px;
    font-weight: 600;
    line-height: 1.38;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  .product-area .single-product-wrap .product-content .price-box {
    margin-top: 7px;
    line-height: 1.1;
  }

  .product-area .single-product-wrap .price-box .new-price {
    color: var(--color-secondary);
    font-size: 20px;
    font-weight: 700;
    line-height: 1.1;
  }

  .product-area .single-product-wrap .price-box .old-price {
    color: #8f8f8f;
    font-size: 13px;
    line-height: 1.1;
  }

  .product-area .single-product-wrap .product-image .product-label .sale-title {
    min-width: 40px;
    padding: 4px 9px;
    border-radius: 4px;
    font-size: 12px;
    font-weight: 700;
    line-height: 1.1;
    text-align: center;
  }

  /*slider arrow*/
.product-area .tab-content{
  position: relative;
}
.product-area .tab-content .button-prev,
.product-area .tab-content .button-next{
  position: absolute;
  bottom: 50%;
  top: auto;
  margin: 0;
  height: 28px;
  width: 28px;
  border: 1px solid rgba(6, 31, 79, 0.16);
  border-radius: 4px;
  color: var(--color-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(255, 255, 255, 0.92);
  box-shadow: 0px 4px 12px rgba(6, 31, 79, 0.08);
  transition: all 0.2s ease-in-out 0s;
} 
.product-area .tab-content .button-prev{
    left: -15px;
}
.product-area .tab-content .button-next{
    right: -15px;
}
.product-area .tab-content .button-prev:after{
    content: "\f104";
    font: normal normal normal 18px/1 FontAwesome;
}
.product-area .tab-content .button-next:after{
    content: "\f105";
    font: normal normal normal 18px/1 FontAwesome;
}
.product-area .tab-content .button-next:hover,
.product-area .tab-content .button-prev:hover{
    color: #fff;
    border-color: var(--color-primary);
    background-color: var(--color-primary);
    box-shadow: 0px 6px 16px rgba(6, 31, 79, 0.12);
}
.product-area .tab-content .button-next.swiper-button-disabled,
.product-area .tab-content .button-prev.swiper-button-disabled{
    opacity: 0.35;
    pointer-events: none;
}
@media(max-width: 767px){
  .product-area .single-product-wrap .product-content .product-title a {
    height: 38px;
    font-size: 13px;
    line-height: 1.45;
  }
  .product-area .single-product-wrap .price-box .new-price {
    font-size: 18px;
  }
  .product-area .single-product-wrap .price-box .old-price {
    display: block;
    margin-top: 3px;
    padding-left: 0;
    font-size: 12px;
  }
  .product-area .single-product-wrap .product-image .product-label .sale-title {
    min-width: 36px;
    padding: 3px 8px;
    font-size: 11px;
  }
}
</style>
